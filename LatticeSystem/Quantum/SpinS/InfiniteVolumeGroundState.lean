import LatticeSystem.Lattice.HypercubicLattice
import LatticeSystem.Math.CStarAlgebra.State
import Mathlib.Algebra.Star.StarAlgHom
import Mathlib.Data.Fintype.Pi
import Mathlib.Data.Int.Interval
import Mathlib.Topology.Algebra.InfiniteSum.Basic

/-!
# Tasaki ¬ß4.3.1: ground states of the infinite-volume antiferromagnetic Heisenberg model

On the infinite hypercubic lattice `‚Ą§ŠĶą` the antiferromagnetic Heisenberg model is treated through
its
algebra of local observables and its states (linear functionals giving expectation values), rather
than vectors in a Hilbert space.  Following Tasaki ¬ß4.3.1, we bundle the abstract data ‚ÄĒ the
`C*`-algebra of observables, the per-site spin operators `Ňú_x^{(őĪ)}`, and the translation
automorphisms `ŌĄ_x` ‚ÄĒ into `InfiniteSpinSystem`, and reuse the existing `C*`-algebra state machinery
(`IsState`, `WeakDual`).

**Definition 4.17**: a *translation-invariant* state `ŌČ` is a **ground state** of the
antiferromagnetic Heisenberg model iff `ŌČ(Ňú_x ¬∑ Ňú_y) = őĶ_GS` for every nearest-neighbor bond
`{x, y} ‚ąą B‚ąě` (eq. (4.3.1)), where `őĶ_GS` is the ground-state energy density (per bond).  This is
the
infinite-volume version of the finite-volume variational characterization, restricted to
translation-invariant states (cf. Definition A.25 / Theorem A.26).

This file sets up the infinite-volume spin system and records Definition 4.17.

Reference: Hal Tasaki, *Physics and Mathematics of Quantum Many-Body Systems* (1st ed., Springer,
2020), ¬ß4.3.1, Definition 4.17, eqs. (4.3.1)‚Äď(4.3.4), pp. 112‚Äď113.
-/

namespace LatticeSystem.Quantum

open scoped ComplexOrder

/-- The **infinite-volume spin system** on `‚Ą§ŠĶą`: the abstract `C*`-algebra `A` of observables (the
quasi-local algebra), the per-site spin operators `spin x őĪ = Ňú_x^{(őĪ)}` (`x ‚ąą ‚Ą§ŠĶą`, `őĪ = 1, 2, 3`),
and the translation automorphisms `transl x = ŌĄ_x` (eq. (4.3.3), bundled as star-algebra
isomorphisms). -/
structure InfiniteSpinSystem (d : ‚Ąē) (A : Type*) [CStarAlgebra A] [NormedSpace ‚Ąā A]
    [StarModule ‚Ąā A] where
  /-- The per-site spin operators `Ňú_x^{(őĪ)}`. -/
  spin : (Fin d ‚Üí ‚Ą§) ‚Üí Fin 3 ‚Üí A
  /-- The translation automorphisms `ŌĄ_x` (eq. (4.3.3)). -/
  transl : (Fin d ‚Üí ‚Ą§) ‚Üí (A ‚ČÉ‚čÜ‚āź[‚Ąā] A)
  /-- `ŌĄ_0` is the identity (the translations form an action of `‚Ą§ŠĶą`). -/
  transl_zero : ‚ąÄ a : A, transl 0 a = a
  /-- The translations compose additively: `ŌĄ_x ‚ąė ŌĄ_y = ŌĄ_{x+y}` (action law). -/
  transl_add : ‚ąÄ (x y : Fin d ‚Üí ‚Ą§) (a : A), transl x (transl y a) = transl (x + y) a
  /-- **Spin covariance** (eq. (4.3.3)): the translation `ŌĄ_x` moves the site-`y` spin operator to
  site `y + x`, `ŌĄ_x(Ňú_y^{(őĪ)}) = Ňú_{y+x}^{(őĪ)}`. -/
  transl_spin : ‚ąÄ (x y : Fin d ‚Üí ‚Ą§) (őĪ : Fin 3), transl x (spin y őĪ) = spin (y + x) őĪ
  /-- The **algebra of local observables** `A_loc`, the `*`-subalgebra generated by the spin
  operators (each acting nontrivially on only finitely many sites). -/
  localAlg : StarSubalgebra ‚Ąā A
  /-- The spin operators are local observables. -/
  spin_mem : ‚ąÄ (x : Fin d ‚Üí ‚Ą§) (őĪ : Fin 3), spin x őĪ ‚ąą localAlg

namespace InfiniteSpinSystem

variable {d : ‚Ąē} {A : Type*} [CStarAlgebra A] [NormedSpace ‚Ąā A] [StarModule ‚Ąā A]

/-- A site `x ‚ąą ‚Ą§ŠĶą` is **even** when its coordinate sum is even (`‚Ą§ŠĶą_even`, eq. (4.3.2)); this is
the
infinite-volume `A`-sublattice. -/
def evenSite (x : Fin d ‚Üí ‚Ą§) : Prop := (‚ąĎ i, x i) % 2 = 0

/-- `{x, y}` is a **nearest-neighbor bond** (`B‚ąě`, eq. (4.3.1)) when `x` and `y` differ in exactly
one
coordinate by `¬Ī1`.  This is the adjacency of the graph-centric infinite hypercubic lattice
`LatticeSystem.Lattice.hypercubicLatticeGraph d`; the local wrapper is kept for the faithful ¬ß4.3
naming (cf. `bond_iff_adj`). -/
def bond (x y : Fin d ‚Üí ‚Ą§) : Prop :=
  (LatticeSystem.Lattice.hypercubicLatticeGraph d).Adj x y

/-- The nearest-neighbor `bond` predicate is exactly the adjacency of the infinite hypercubic
lattice graph, unfolded to its differ-in-one-coordinate-by-`¬Ī1` form. -/
theorem bond_iff_adj {x y : Fin d ‚Üí ‚Ą§} :
    bond x y ‚ÜĒ ‚ąÉ i : Fin d, |x i - y i| = 1 ‚ąß ‚ąÄ j, j ‚Č† i ‚Üí x j = y j :=
  LatticeSystem.Lattice.hypercubicLatticeGraph_adj

/-- The **bond spin‚Äďspin operator** `Ňú_x ¬∑ Ňú_y = ő£_őĪ Ňú_x^{(őĪ)} Ňú_y^{(őĪ)}`. -/
noncomputable def spinDot (S : InfiniteSpinSystem d A) (x y : Fin d ‚Üí ‚Ą§) : A :=
  ‚ąĎ őĪ : Fin 3, S.spin x őĪ * S.spin y őĪ

/-- A state `ŌĀ` is **translation invariant** when `ŌĀ(ŌĄ_x a) = ŌĀ(a)` for every observable `a` and
every **even** translation `x ‚ąą ‚Ą§ŠĶą_even`.  This is exactly Tasaki's convention for ¬ß4.3: he
restricts
the translations to the even sublattice `‚Ą§ŠĶą_even`, "anticipating antiferromagnetic order" (the N√©el
state is invariant under even translations but *not* under odd ones), and footnote 35 explicitly
notes this is a deliberate restriction of the general (all-`x`) notion to even translations.  So the
`evenSite` quantifier is faithful to Definition 4.17, not a weakening. -/
def TranslationInvariant (S : InfiniteSpinSystem d A) (ŌĀ : WeakDual ‚Ąā A) : Prop :=
  ‚ąÄ a : A, ‚ąÄ x : Fin d ‚Üí ‚Ą§, evenSite x ‚Üí ŌĀ (S.transl x a) = ŌĀ a

/-- **Tasaki Definition 4.17 (ground state of the infinite-volume antiferromagnetic Heisenberg
model).**  Given the ground-state energy density `őĶGS` (per bond, eq. (4.3.4)), a state `ŌĀ` is a
*ground state* iff it is a state, translation invariant, and assigns every nearest-neighbor bond the
energy density: `ŌĀ(Ňú_x ¬∑ Ňú_y) = őĶGS` for all `{x, y} ‚ąą B‚ąě`. -/
def IsInfiniteVolumeGroundState (S : InfiniteSpinSystem d A) (őĶGS : ‚ĄĚ) (ŌĀ : WeakDual ‚Ąā A) : Prop :=
  LatticeSystem.Math.IsState ŌĀ ‚ąß TranslationInvariant S ŌĀ ‚ąß
    ‚ąÄ x y : Fin d ‚Üí ‚Ą§, bond x y ‚Üí ŌĀ (spinDot S x y) = (őĶGS : ‚Ąā)

instance : DecidablePred (evenSite (d := d)) := fun x => Int.decEq ((‚ąĎ i, x i) % 2) 0

/-- The finite hypercubic box `őõ_n = {x ‚ąą ‚Ą§ŠĶą : ‚ąín < xŠĶĘ ‚Č§ n}` (even side length `2n`, volume `(2n)ŠĶą`,
centered at the origin, cf. eq. (3.1.2)), as a `Finset`. -/
noncomputable def latticeBox (d n : ‚Ąē) : Finset (Fin d ‚Üí ‚Ą§) :=
  LatticeSystem.Lattice.hypercubicBox d n

/-- The finite box `latticeBox d n` is the graph-centric `hypercubicBox d n`. -/
theorem latticeBox_eq_hypercubicBox (d n : ‚Ąē) :
    latticeBox d n = LatticeSystem.Lattice.hypercubicBox d n := rfl

/-- The **bulk operator** `√ā_n = ő£_{x ‚ąą őõ_n ‚ą© ‚Ą§ŠĶą_even} ŌĄ_x(√ā)` (eq. (4.3.5)): the sum of the
translated observables over the even sites of the centered box `őõ_n` (side `2n`). -/
noncomputable def bulkOp (S : InfiniteSpinSystem d A) (√ā : A) (n : ‚Ąē) : A :=
  ‚ąĎ x ‚ąą (latticeBox d n).filter evenSite, S.transl x √ā

/-- **Tasaki Definition 4.18 (ergodic state).**  A translation-invariant state `ŌĀ` is *ergodic* iff,
for every self-adjoint **local** observable `√ā ‚ąą A_loc`, the fluctuation of the bulk density
`√ā_L / LŠĶą` (with side length `L = 2n`, volume `LŠĶą = (2n)ŠĶą`) vanishes in the infinite-volume limit
(eq. (4.3.6)):
`lim_{n‚ÜĎ‚ąě} [ ŌĀ(√ā_n¬≤) / ((2n)ŠĶą)¬≤ ‚ąí (ŌĀ(√ā_n) / (2n)ŠĶą)¬≤ ] = 0`.
The vanishing of the fluctuation is the law of large numbers for densities ‚ÄĒ the mark of a
macroscopically "healthy" state.  (`√ā` self-adjoint makes `ŌĀ(√ā_n)` and `ŌĀ(√ā_n¬≤)` real, so the real
parts carry the content; the index is shifted by one to avoid the empty `n = 0` box.) -/
def IsErgodic (S : InfiniteSpinSystem d A) (ŌĀ : WeakDual ‚Ąā A) : Prop :=
  LatticeSystem.Math.IsState ŌĀ ‚ąß TranslationInvariant S ŌĀ ‚ąß
    ‚ąÄ √ā : A, √ā ‚ąą S.localAlg ‚Üí IsSelfAdjoint √ā ‚Üí
      Filter.Tendsto
        (fun n : ‚Ąē =>
          (ŌĀ ((bulkOp S √ā (n + 1)) ^ 2)).re / ((2 * ((n : ‚ĄĚ) + 1)) ^ d) ^ 2
            - ((ŌĀ (bulkOp S √ā (n + 1))).re / (2 * ((n : ‚ĄĚ) + 1)) ^ d) ^ 2)
        Filter.atTop (nhds 0)

/-- **Tasaki Definition 4.19 (physical ground state).**  A translation-invariant ground state `ŌČ` of
the antiferromagnetic Heisenberg model is a *physical ground state* when it is ergodic. -/
def IsPhysicalGroundState (S : InfiniteSpinSystem d A) (őĶGS : ‚ĄĚ) (ŌČ : WeakDual ‚Ąā A) : Prop :=
  IsInfiniteVolumeGroundState S őĶGS ŌČ ‚ąß IsErgodic S ŌČ

/-- The **staggered sign** `őĶ_x = (‚ąí1)^{ő£_i x_i}` (`+1` on even sites, `‚ąí1` on odd), as a real
number; the N√©el magnetization alternates with this sign. -/
def staggeredSign (x : Fin d ‚Üí ‚Ą§) : ‚ĄĚ := if Even (‚ąĎ i, x i) then 1 else -1

/-- A vector `n : Fin 3 ‚Üí ‚ĄĚ` is a **unit vector** when `ő£_őĪ (n őĪ)¬≤ = 1`. -/
def IsUnitVector (n : Fin 3 ‚Üí ‚ĄĚ) : Prop := (‚ąĎ őĪ, (n őĪ) ^ 2) = 1

/-! ### Parity bridge to the graph-centric sublattices

The ¬ß4.3 quantum-side parity helpers `evenSite` / `staggeredSign` agree with the
graph-centric even/odd sublattices `Lattice.hypercubicEvenSublattice` /
`hypercubicOddSublattice` of the bipartite hypercubic lattice (Issue #4557). -/

/-- A site is **even** (`evenSite`) iff it lies in the graph-centric even
sublattice `‚Ą§ŠĶą_even` (the A-sublattice of the bipartite hypercubic lattice). -/
theorem evenSite_iff_mem_hypercubicEvenSublattice (x : Fin d ‚Üí ‚Ą§) :
    evenSite x ‚ÜĒ x ‚ąą LatticeSystem.Lattice.hypercubicEvenSublattice d := by
  simp only [evenSite, LatticeSystem.Lattice.hypercubicEvenSublattice, Set.mem_setOf_eq,
    Int.even_iff]

/-- A site lies in the graph-centric odd sublattice `‚Ą§ŠĶą_odd` (the B-sublattice)
iff it is **not** an even site. -/
theorem mem_hypercubicOddSublattice_iff_not_evenSite (x : Fin d ‚Üí ‚Ą§) :
    x ‚ąą LatticeSystem.Lattice.hypercubicOddSublattice d ‚ÜĒ ¬¨ evenSite x := by
  simp only [LatticeSystem.Lattice.hypercubicOddSublattice, Set.mem_setOf_eq, evenSite,
    Int.even_iff]

/-- The staggered sign is `+1` exactly on the even sublattice. -/
theorem staggeredSign_eq_one_iff_mem_hypercubicEvenSublattice (x : Fin d ‚Üí ‚Ą§) :
    staggeredSign x = 1 ‚ÜĒ x ‚ąą LatticeSystem.Lattice.hypercubicEvenSublattice d := by
  rw [show (x ‚ąą LatticeSystem.Lattice.hypercubicEvenSublattice d) ‚ÜĒ Even (‚ąĎ i, x i) from Iff.rfl]
  unfold staggeredSign
  by_cases h : Even (‚ąĎ i, x i) <;> norm_num [h]

/-- The staggered sign is `‚ąí1` exactly on the odd sublattice. -/
theorem staggeredSign_eq_neg_one_iff_mem_hypercubicOddSublattice (x : Fin d ‚Üí ‚Ą§) :
    staggeredSign x = -1 ‚ÜĒ x ‚ąą LatticeSystem.Lattice.hypercubicOddSublattice d := by
  rw [show (x ‚ąą LatticeSystem.Lattice.hypercubicOddSublattice d) ‚ÜĒ ¬¨ Even (‚ąĎ i, x i) from Iff.rfl]
  unfold staggeredSign
  by_cases h : Even (‚ąĎ i, x i) <;> norm_num [h]

/-- **`őĶGS` is the ground-state energy density of `S`** (an uninterpreted documented predicate): the
per-bond ground-state energy density `őĶ_GS = lim_L E_GS,L / |B_L|` (eq. (4.3.4)) of the
antiferromagnetic Heisenberg model `S`.  Kept uninterpreted so Theorem 4.20 asserts the existence of
ground states only for the genuine `(S, őĶ_GS)` data (and cannot be instantiated with an arbitrary
`őĶGS` unrelated to `S`, which would be inconsistent for degenerate systems). -/
axiom IsGroundStateEnergyDensity {d : ‚Ąē} {A : Type*} [CStarAlgebra A] [NormedSpace ‚Ąā A]
    [StarModule ‚Ąā A] : InfiniteSpinSystem d A ‚Üí ‚ĄĚ ‚Üí Prop

/-- **The model exhibits staggered long-range order with order parameter `m‚ąó`** (an uninterpreted
documented predicate, the infinite-volume LRO assumption).  Tasaki's construction of the
symmetry-breaking ground states `ŌČ_n` (Theorem 4.20) presumes the model has N√©el long-range order
(`m‚ąó > 0`); in one dimension there is no such order (cf. Corollary 4.3), so this hypothesis is not
available there.  Kept uninterpreted so the existence of `ŌČ_n` is genuinely conditional on
long-range
order, not trivially dischargeable. -/
axiom HasStaggeredLRO {d : ‚Ąē} {A : Type*} [CStarAlgebra A] [NormedSpace ‚Ąā A] [StarModule ‚Ąā A] :
    InfiniteSpinSystem d A ‚Üí ‚ĄĚ ‚Üí Prop

/-- **Tasaki Theorem 4.20 for `ŌČ_0` (the symmetric infinite-volume ground state), AXIOM.**  The
infinite-volume state `ŌČ_0` built as the `L‚ÜĎ‚ąě` limit of the unique finite-volume ground-state
expectation `‚ü®ő¶_GS|¬∑|ő¶_GS‚ü©` (eq. (4.3.7)) is a translation-invariant ground state with vanishing
single-site magnetization `ŌČ_0(Ňú_x^{(őĪ)}) = 0` (eq. (4.3.9)): it exhibits long-range order but
**no**
spontaneous symmetry breaking.  The `L‚ÜĎ‚ąě` limit's existence is assumed (Banach‚ÄďAlaoglu, Theorem
A.24); recorded as a documented axiom asserting the limit state exists with the stated properties.
Conditional on `őĶGS` being the genuine ground-state energy density of `S` (`hőĶ`), so it cannot be
applied with an arbitrary `őĶGS`. -/
axiom theorem_4_20_omega0 (S : InfiniteSpinSystem d A) (őĶGS : ‚ĄĚ)
    (hőĶ : IsGroundStateEnergyDensity S őĶGS) :
    ‚ąÉ ŌČ0 : WeakDual ‚Ąā A, IsInfiniteVolumeGroundState S őĶGS ŌČ0 ‚ąß
      ‚ąÄ (x : Fin d ‚Üí ‚Ą§) (őĪ : Fin 3), ŌČ0 (S.spin x őĪ) = 0

/-- **Tasaki Theorem 4.20 for `ŌČ_n` (the symmetry-breaking infinite-volume ground states), AXIOM.**
Assuming the model has staggered long-range order with order parameter `m‚ąó > 0` (`HasStaggeredLRO`),
for every unit direction `n ‚ąą ‚ĄĚ¬≥` the infinite-volume state `ŌČ_n` built as the `L‚ÜĎ‚ąě` limit of the
symmetry-breaking low-lying state expectation `‚ü®őě_n|¬∑|őě_n‚ü©` (eq. (4.3.8)) is a translation-invariant
ground state with N√©el magnetization `ŌČ_n(Ňú_x^{(őĪ)}) = (‚ąí1)^x m‚ąó n_őĪ` (eq. (4.3.10)): it exhibits
long-range order **and** full spontaneous symmetry breaking in the direction `n`.  Recorded as a
documented axiom; the `m‚ąó` is tied to long-range order (not arbitrary), so `ŌČ_n` exists only in the
ordered regime (vacuous in one dimension). -/
axiom theorem_4_20_omegaN (S : InfiniteSpinSystem d A) (őĶGS : ‚ĄĚ)
    (hőĶ : IsGroundStateEnergyDensity S őĶGS) (mStar : ‚ĄĚ) (hm : 0 < mStar)
    (hLRO : HasStaggeredLRO S mStar) (n : Fin 3 ‚Üí ‚ĄĚ) (hn : IsUnitVector n) :
    ‚ąÉ ŌČn : WeakDual ‚Ąā A, IsInfiniteVolumeGroundState S őĶGS ŌČn ‚ąß
      ‚ąÄ (x : Fin d ‚Üí ‚Ą§) (őĪ : Fin 3),
        ŌČn (S.spin x őĪ) = ((staggeredSign x : ‚ĄĚ) : ‚Ąā) * (mStar : ‚Ąā) * (n őĪ : ‚Ąā)

/-- **Tasaki Conjecture 4.21 (the symmetry-breaking ground states are physical), as a `Prop`
STATEMENT ONLY** (eq. after (4.3.10)).  This registers the *unproven* conjecture as a numbered,
searchable item; it is a `def ‚Ä¶ : Prop` and is **never asserted true** (no `axiom`/`theorem` derives
it ‚ÄĒ that would be unsound, the conjecture being open).

The statement: every symmetry-breaking infinite-volume ground state `ŌČ` ‚ÄĒ a translation-invariant
ground state with the N√©el magnetization `ŌČ(Ňú_x^{(őĪ)}) = (‚ąí1)^x m‚ąó n_őĪ` for some `m‚ąó > 0` and unit
direction `n` (the `ŌČ_n` of Theorem 4.20) ‚ÄĒ is **ergodic**, hence a *physical* ground state
(Definition 4.19).  This conjecture motivates identifying the low-lying states `|őě_n‚ü©` as physical
"ground states".  Tasaki believes it likely valid but it is open; we record it without asserting
it. -/
def conjecture_4_21 (S : InfiniteSpinSystem d A) (őĶGS : ‚ĄĚ) : Prop :=
  ‚ąÄ (mStar : ‚ĄĚ), 0 < mStar ‚Üí ‚ąÄ (n : Fin 3 ‚Üí ‚ĄĚ), IsUnitVector n ‚Üí
    ‚ąÄ (ŌČ : WeakDual ‚Ąā A), IsInfiniteVolumeGroundState S őĶGS ŌČ ‚Üí
      (‚ąÄ (x : Fin d ‚Üí ‚Ą§) (őĪ : Fin 3),
        ŌČ (S.spin x őĪ) = ((staggeredSign x : ‚ĄĚ) : ‚Ąā) * (mStar : ‚Ąā) * (n őĪ : ‚Ąā)) ‚Üí
      IsErgodic S ŌČ

end InfiniteSpinSystem

end LatticeSystem.Quantum

/-! ## 4. Separating real and imaginary parts -/

/-- The real part of a real multiple of a complex number. -/
theorem ofRealMulReE6 (c : ℝ) (a : ℂ) : ((c : ℂ) * a).re = c * a.re := by
  simp [Complex.mul_re]

/-- The imaginary part of a real multiple of a complex number. -/
theorem ofRealMulImE6 (c : ℝ) (a : ℂ) : ((c : ℂ) * a).im = c * a.im := by
  simp [Complex.mul_im]

/-- A nonzero complex number has a strictly positive sum of squared real and imaginary parts. -/
theorem sqAddSqPosOfNeZeroE6 (z : ℂ) (h : z ≠ 0) : 0 < z.re ^ 2 + z.im ^ 2 := by
  have hz := Complex.normSq_pos.mpr h
  rw [Complex.normSq_apply] at hz
  nlinarith [hz]

/-- **Real-linear part of a 2-term equation with real coefficients.**  Applied to
`Complex.re` and to `Complex.im`, it splits the complex eigenvalue equation of the sector
block into two copies of the same real system. -/
theorem row2PartE6 (φ : ℂ → ℝ) (hadd : ∀ z w : ℂ, φ (z + w) = φ z + φ w)
    (hmul : ∀ (c : ℝ) (a : ℂ), φ ((c : ℂ) * a) = c * φ a)
    { c0 c1 μ : ℝ}
    { a0 a1 z : ℂ}
    (h : ((c0 : ℝ) : ℂ) * a0 + ((c1 : ℝ) : ℂ) * a1
      = ((μ : ℝ) : ℂ) * z) :
    c0 * φ a0 + c1 * φ a1
      = μ * φ z := by
  have h' := congrArg φ h
  rw [hadd,
    hmul, hmul, hmul] at h'
  exact h'

/-- **Real-linear part of a 3-term equation with real coefficients.**  Applied to
`Complex.re` and to `Complex.im`, it splits the complex eigenvalue equation of the sector
block into two copies of the same real system. -/
theorem row3PartE6 (φ : ℂ → ℝ) (hadd : ∀ z w : ℂ, φ (z + w) = φ z + φ w)
    (hmul : ∀ (c : ℝ) (a : ℂ), φ ((c : ℂ) * a) = c * φ a)
    { c0 c1 c2 μ : ℝ}
    { a0 a1 a2 z : ℂ}
    (h : ((c0 : ℝ) : ℂ) * a0 + ((c1 : ℝ) : ℂ) * a1 + ((c2 : ℝ) : ℂ) * a2
      = ((μ : ℝ) : ℂ) * z) :
    c0 * φ a0 + c1 * φ a1 + c2 * φ a2
      = μ * φ z := by
  have h' := congrArg φ h
  rw [hadd, hadd,
    hmul, hmul, hmul, hmul] at h'
  exact h'

/-- **Real-linear part of a 4-term equation with real coefficients.**  Applied to
`Complex.re` and to `Complex.im`, it splits the complex eigenvalue equation of the sector

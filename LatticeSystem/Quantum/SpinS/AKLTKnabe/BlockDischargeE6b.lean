    { c0 c1 c2 c3 μ : ℝ}
    { a0 a1 a2 a3 z : ℂ}
    (h : ((c0 : ℝ) : ℂ) * a0 + ((c1 : ℝ) : ℂ) * a1 + ((c2 : ℝ) : ℂ) * a2 + ((c3 : ℝ) : ℂ) * a3
      = ((μ : ℝ) : ℂ) * z) :
    c0 * φ a0 + c1 * φ a1 + c2 * φ a2 + c3 * φ a3
      = μ * φ z := by
  have h' := congrArg φ h
  rw [hadd, hadd, hadd,
    hmul, hmul, hmul, hmul, hmul] at h'
  exact h'

/-- **Real-linear part of a 5-term equation with real coefficients.**  Applied to

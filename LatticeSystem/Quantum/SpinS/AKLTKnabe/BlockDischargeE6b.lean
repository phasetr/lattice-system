/-! ## 5. The sum-of-squares certificates of the sectors -/

/-- **The sector certificate for `V_1`.**  For *every* real vector `w` indexed by the
configurations of `V_1`, the quadratic form of `ĥ|V_1` dominates `(2/5)‖w‖²`.  The proof
is the exact `LDLᵀ` factorisation of `ĥ|V_1 − (2/5) I`, whose 4 pivots are all strictly
positive; it is transcribed as the polynomial identity `hid`, so no eigenvalue and no
numerical table is used. -/
theorem quadV1E6 (μ w0 w1 w2 w3 : ℝ)
    (h0 : 5 / 2 * w0 + 1 / 2 * w1 = μ * w0)
    (h1 : 1 / 2 * w0 + 2 * w1 + 1 / 2 * w2 = μ * w1)
    (h2 : 1 / 2 * w1 + 2 * w2 + 1 / 2 * w3 = μ * w2)
    (h3 : 1 / 2 * w2 + 5 / 2 * w3 = μ * w3)
    : 2 / 5 * (w0 ^ 2 + w1 ^ 2 + w2 ^ 2 + w3 ^ 2)
      ≤ μ * (w0 ^ 2 + w1 ^ 2 + w2 ^ 2 + w3 ^ 2) := by
  have hq : 5 / 2 * w0 ^ 2 + 2 * w1 ^ 2 + 2 * w2 ^ 2 + 5 / 2 * w3 ^ 2 + 1 * w0 * w1 + 1 * w1 * w2 +
      1 * w2 * w3
      = μ * (w0 ^ 2 + w1 ^ 2 + w2 ^ 2 + w3 ^ 2) := by
    linear_combination w0 * h0 + w1 * h1 + w2 * h2 + w3 * h3
  have hid : 5 / 2 * w0 ^ 2 + 2 * w1 ^ 2 + 2 * w2 ^ 2 + 5 / 2 * w3 ^ 2 + 1 * w0 * w1 + 1 * w1 * w2 +
      1 * w2 * w3
      - 2 / 5 * (w0 ^ 2 + w1 ^ 2 + w2 ^ 2 + w3 ^ 2)
      = (1 / 210) * (21 * w0 + 5 * w1) ^ 2
      + (1 / 65310) * (311 * w1 + 105 * w2) ^ 2
      + (1 / 13842610) * (4451 * w2 + 1555 * w3) ^ 2
      + (42848 / 22255) * (w3) ^ 2
      := by ring
  have hnn : (0 : ℝ) ≤ (1 / 210) * (21 * w0 + 5 * w1) ^ 2 + (1 / 65310) * (311 * w1 +
    105 * w2) ^ 2 +
      (1 / 13842610) * (4451 * w2 + 1555 * w3) ^ 2 + (42848 / 22255) * (w3) ^ 2
      := by positivity
  linarith [hq, hid, hnn]

/-- **The sector certificate for `V_2`.**  For *every* real vector `w` indexed by the
configurations of `V_2`, the quadratic form of `ĥ|V_2` dominates `(2/5)‖w‖²`.  The proof
is the exact `LDLᵀ` factorisation of `ĥ|V_2 − (2/5) I`, whose 10 pivots are all strictly
positive; it is transcribed as the polynomial identity `hid`, so no eigenvalue and no
numerical table is used. -/
theorem quadV2E6 (μ w0 w1 w2 w3 w4 w5 w6 w7 w8 w9 : ℝ)
    (h0 : 13 / 6 * w0 + 1 / 3 * w1 + 1 / 6 * w2 = μ * w0)
    (h1 : 1 / 3 * w0 + 13 / 6 * w1 + 1 / 3 * w2 + 1 / 2 * w3 = μ * w1)
    (h2 : 1 / 6 * w0 + 1 / 3 * w1 + 4 / 3 * w2 + 1 / 3 * w4 + 1 / 6 * w5 = μ * w2)
    (h3 : 1 / 2 * w1 + 3 / 2 * w3 + 1 / 2 * w4 + 1 / 2 * w6 = μ * w3)
    (h4 : 1 / 3 * w2 + 1 / 2 * w3 + 5 / 3 * w4 + 1 / 3 * w5 + 1 / 2 * w7 = μ * w4)
    (h5 : 1 / 6 * w2 + 1 / 3 * w4 + 4 / 3 * w5 + 1 / 3 * w8 + 1 / 6 * w9 = μ * w5)
    (h6 : 1 / 2 * w3 + 2 * w6 + 1 / 2 * w7 = μ * w6)
    (h7 : 1 / 2 * w4 + 1 / 2 * w6 + 3 / 2 * w7 + 1 / 2 * w8 = μ * w7)
    (h8 : 1 / 3 * w5 + 1 / 2 * w7 + 13 / 6 * w8 + 1 / 3 * w9 = μ * w8)
    (h9 : 1 / 6 * w5 + 1 / 3 * w8 + 13 / 6 * w9 = μ * w9)
    : 2 / 5 * (w0 ^ 2 + w1 ^ 2 + w2 ^ 2 + w3 ^ 2 + w4 ^ 2 + w5 ^ 2 + w6 ^ 2 + w7 ^ 2 + w8 ^ 2 +
      w9 ^ 2)
      ≤ μ * (w0 ^ 2 + w1 ^ 2 + w2 ^ 2 + w3 ^ 2 + w4 ^ 2 + w5 ^ 2 + w6 ^ 2 + w7 ^ 2 + w8 ^ 2 +
        w9 ^ 2) := by
  have hq : 13 / 6 * w0 ^ 2 + 13 / 6 * w1 ^ 2 + 4 / 3 * w2 ^ 2 + 3 / 2 * w3 ^ 2 + 5 / 3 * w4 ^ 2 +
      4 / 3 * w5 ^ 2 + 2 * w6 ^ 2 + 3 / 2 * w7 ^ 2 + 13 / 6 * w8 ^ 2 + 13 / 6 * w9 ^ 2 +
        2 / 3 * w0 * w1 +
      1 / 3 * w0 * w2 + 2 / 3 * w1 * w2 + 1 * w1 * w3 + 2 / 3 * w2 * w4 + 1 / 3 * w2 * w5 +
        1 * w3 * w4 +
      1 * w3 * w6 + 2 / 3 * w4 * w5 + 1 * w4 * w7 + 2 / 3 * w5 * w8 + 1 / 3 * w5 * w9 +
        1 * w6 * w7 +
      1 * w7 * w8 + 2 / 3 * w8 * w9
      = μ * (w0 ^ 2 + w1 ^ 2 + w2 ^ 2 + w3 ^ 2 + w4 ^ 2 + w5 ^ 2 + w6 ^ 2 + w7 ^ 2 + w8 ^ 2 +
        w9 ^ 2) := by
    linear_combination w0 * h0 + w1 * h1 + w2 * h2 + w3 * h3 + w4 * h4 + w5 * h5 + w6 * h6 +
      w7 * h7 + w8 * h8 + w9 * h9
  have hid : 13 / 6 * w0 ^ 2 + 13 / 6 * w1 ^ 2 + 4 / 3 * w2 ^ 2 + 3 / 2 * w3 ^ 2 + 5 / 3 * w4 ^ 2 +
      4 / 3 * w5 ^ 2 + 2 * w6 ^ 2 + 3 / 2 * w7 ^ 2 + 13 / 6 * w8 ^ 2 + 13 / 6 * w9 ^ 2 +
        2 / 3 * w0 * w1 +
      1 / 3 * w0 * w2 + 2 / 3 * w1 * w2 + 1 * w1 * w3 + 2 / 3 * w2 * w4 + 1 / 3 * w2 * w5 +
        1 * w3 * w4 +
      1 * w3 * w6 + 2 / 3 * w4 * w5 + 1 * w4 * w7 + 2 / 3 * w5 * w8 + 1 / 3 * w5 * w9 +
        1 * w6 * w7 +
      1 * w7 * w8 + 2 / 3 * w8 * w9
      - 2 / 5 * (w0 ^ 2 + w1 ^ 2 + w2 ^ 2 + w3 ^ 2 + w4 ^ 2 + w5 ^ 2 + w6 ^ 2 + w7 ^ 2 + w8 ^ 2 +
        w9 ^ 2)
      = (1 / 1590) * (53 * w0 + 10 * w1 + 5 * w2) ^ 2
      + (1 / 478590) * (903 * w1 + 160 * w2 + 265 * w3) ^ 2
      + (1 / 70461090) * (7803 * w2 - 800 * w3 + 3010 * w4 + 1505 * w5) ^ 2
      + (1 / 51739508160) * (221024 * w3 + 125045 * w4 + 4000 * w5 + 117045 * w6) ^ 2
      + (1 / 4083371984960) * (1847479 * w4 + 573280 * w5 - 625225 * w6 + 1105120 * w7) ^ 2
      + (1 / 2520134298509190) * (
        45469787 * w5 + 4363500 * w6 - 8599200 * w7 + 18474790 * w8 + 9237395 * w9) ^ 2
      + (1 / 63675667140192635) * (
        280079021 * w6 + 155529280 * w7 - 7272500 * w8 - 3636250 * w9) ^ 2
      + (1 / 3072546489636460510) * (1097028431 * w7 + 1626707105 * w8 + 113156000 * w9) ^ 2
      + (32 / 80353388753540555) * (43947843 * w8 + 11729710 * w9) ^ 2
      + (122588128 / 73246405) * (w9) ^ 2
      := by ring
  have hnn : (0 : ℝ) ≤ (1 / 1590) * (53 * w0 + 10 * w1 + 5 * w2) ^ 2 +
      (1 / 478590) * (903 * w1 + 160 * w2 + 265 * w3) ^ 2 +
      (1 / 70461090) * (7803 * w2 - 800 * w3 + 3010 * w4 + 1505 * w5) ^ 2 +
      (1 / 51739508160) * (221024 * w3 + 125045 * w4 + 4000 * w5 + 117045 * w6) ^ 2 +
      (1 / 4083371984960) * (1847479 * w4 + 573280 * w5 - 625225 * w6 + 1105120 * w7) ^ 2 +
      (1 / 2520134298509190) * (45469787 * w5 + 4363500 * w6 - 8599200 * w7 + 18474790 * w8 +
          9237395 * w9) ^ 2 +
      (1 / 63675667140192635) * (280079021 * w6 + 155529280 * w7 - 7272500 * w8 - 3636250 * w9) ^ 2
          +
      (1 / 3072546489636460510) * (1097028431 * w7 + 1626707105 * w8 + 113156000 * w9) ^ 2 +
      (32 / 80353388753540555) * (43947843 * w8 + 11729710 * w9) ^ 2 +
      (122588128 / 73246405) * (w9) ^ 2
      := by positivity
  linarith [hq, hid, hnn]


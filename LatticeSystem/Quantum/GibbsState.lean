import LatticeSystem.Quantum.ManyBody
import Mathlib.Analysis.Normed.Algebra.MatrixExponential
import Mathlib.LinearAlgebra.Matrix.NonsingularInverse

/-!
# Gibbs state for finite-volume quantum systems

Following Tasaki *Physics and Mathematics of Quantum Many-Body Systems*,
┬π3.3, this module defines the finite-volume quantum Gibbs state

  `╧Β_╬▓ = exp(-╬▓ H) / Z`,   `Z = Tr(exp(-╬▓ H))`,

for a Hermitian Hamiltonian `H : ManyBodyOp ╬δ` and inverse temperature
`╬▓ : έΕζ`. We prove:

* `gibbsExp_isHermitian` έΑΦ `exp(-╬▓ H)` is Hermitian.
* `gibbsState_trace` έΑΦ `Tr(╧Β_╬▓) = 1` (given `Z έΚι 0`).
* `gibbsState_isHermitian` έΑΦ `╧Β_╬▓` is Hermitian.
* `gibbsExpectation_one` έΑΦ `έθρ1έθσ_╬▓ = 1` (given `Z έΚι 0`).
* `gibbsExpectation_neg`, `gibbsExpectation_sub`, `gibbsExpectation_sum`
  έΑΦ full linearity API: negation, subtraction, finite sums commute
  with `gibbsExpectation`.
* `gibbsExp_commute_hamiltonian`, `gibbsState_commute_hamiltonian` έΑΦ
  `[exp(-╬▓ H), H] = 0` and `[╧Β_╬▓, H] = 0`, i.e. the Gibbs state is
  stationary under the dynamics generated by `H` (Tasaki ┬π3.3, p. 80).
* `Matrix.trace_mul_star_of_isHermitian` έΑΦ generic auxiliary:
  for Hermitian matrices `A`, `B`, `star (Tr(A ┬╖ B)) = Tr(A ┬╖ B)`.
* `gibbsExpectation_star_of_isHermitian`,
  `gibbsExpectation_im_of_isHermitian`,
  `gibbsExpectation_ofReal_re_eq_of_isHermitian` έΑΦ for Hermitian `H`
  and Hermitian observable `O`, the expectation `έθρOέθσ_╬▓` is real
  (in three equivalent forms: fixed by `star`, vanishing imaginary
  part, equal to its real part cast to `έΕΓ`).
* `gibbsExpectation_mul_hamiltonian_comm`,
  `gibbsExpectation_commutator_hamiltonian` έΑΦ conservation laws:
  `έθρH ┬╖ Aέθσ_╬▓ = έθρA ┬╖ Hέθσ_╬▓` and `έθρ[H, A]έθσ_╬▓ = 0` (Tasaki ┬π3.3, p. 80).
* `gibbsExpectation_sq_im_of_isHermitian` έΑΦ for Hermitian `H, O`,
  `(έθρO ┬╖ Oέθσ_╬▓).im = 0` (variance precursor).
* `gibbsExpectation_pow_im_of_isHermitian` έΑΦ for Hermitian `H, O` and
  any `n : έΕΧ`, `(έθρO ^ nέθσ_╬▓).im = 0` (all natural-power moments real).
* `gibbsVariance ╬▓ H O` έΑΦ canonical-ensemble variance
  `έθρO┬▓έθσ_╬▓ έΙΤ (έθρOέθσ_╬▓)┬▓` and its realness for Hermitian observables
  (`gibbsVariance_im_of_isHermitian`).
* `gibbsCovariance ╬▓ H A B` έΑΦ canonical-ensemble (complex) covariance
  `έθρA ┬╖ Bέθσ_╬▓ έΙΤ έθρAέθσ_╬▓ ┬╖ έθρBέθσ_╬▓`; `gibbsCovariance_self_eq_variance`
  recovers the variance at `A = B`.
* `gibbsCovarianceSymm ╬▓ H A B` έΑΦ symmetric (real-valued for Hermitian
  observables) covariance
  `(1/2) ┬╖ έθρA ┬╖ B + B ┬╖ Aέθσ_╬▓ έΙΤ έθρAέθσ_╬▓ ┬╖ έθρBέθσ_╬▓`. Self-equals-variance
  at `A = B` and realness for Hermitian `A, B`
  (`gibbsCovarianceSymm_im_of_isHermitian`).
* `Matrix.trace_mul_conjTranspose_swap_of_isHermitian` έΑΦ generic
  helper: for Hermitian `╧Β`, `star Tr(╧Β ┬╖ X) = Tr(╧Β ┬╖ Xά┤┤)`.
* `gibbsExpectation_star_swap_of_isHermitian` έΑΦ for Hermitian `H, A, B`,
  `star έθρA ┬╖ Bέθσ_╬▓ = έθρB ┬╖ Aέθσ_╬▓`.
* `gibbsExpectation_anticommutator_im`,
  `gibbsExpectation_commutator_re` έΑΦ under Hermitian `H, A, B`,
  the anticommutator expectation is real and the commutator expectation
  is purely imaginary.
* `gibbsExpectation_mul_hamiltonian_im` έΑΦ for Hermitian `H, O`,
  `(έθρH ┬╖ Oέθσ_╬▓).im = 0` (energy-mode expectation reality).
* `gibbsState_zero`, `gibbsState_zero_inv`, `gibbsExpectation_zero` έΑΦ
  high-temperature limit `╧Β_0 = (1/dim) ┬╖ I`, its matrix inverse
  `╧Β_0έΒ╗┬╣ = dim ┬╖ I`, and `έθρAέθσ_0 = (1/dim) ┬╖ Tr A` (Tasaki ┬π3.3, p. 78).
* `gibbsExp_add`, `gibbsExp_neg_mul_self`, `gibbsExp_self_mul_neg`,
  `gibbsExp_isUnit`, `gibbsExp_ne_zero` έΑΦ one-parameter group property
  in `╬▓`: `e^{-(╬▓έΓΒ+╬▓έΓΓ)H} = e^{-╬▓έΓΒH} ┬╖ e^{-╬▓έΓΓH}`,
  `e^{╬▓H} ┬╖ e^{-╬▓H} = 1`, hence `e^{-╬▓H}` is invertible (and in
  particular nonzero). Foundation for KMS / Wick rotation.
* `gibbsState_ne_zero` έΑΦ `╧Β_╬▓ έΚι 0` whenever `Z(╬▓) έΚι 0`.
* `gibbsState_inv` έΑΦ when `Z(╬▓) έΚι 0`,
  `(╧Β_╬▓)έΒ╗┬╣ = Z(╬▓) ┬╖ e^{╬▓ H}`. Generalises `gibbsState_zero_inv`
  beyond ╬▓ = 0.
* `partitionFn_smul_gibbsState_eq_gibbsExp`,
  `partitionFn_mul_gibbsExpectation_eq` έΑΦ when `Z(╬▓) έΚι 0`,
  `Z(╬▓) ┬╖ ╧Β_╬▓ = e^{-╬▓ H}` (canonical rescaled identity) and
  `Z(╬▓) ┬╖ έθρAέθσ_╬▓ = Tr(e^{-╬▓ H} ┬╖ A)` (canonical normalisation).
* `gibbsExp_natCast_mul`, `gibbsExp_two_mul` έΑΦ exact discrete
  semigroup identity `gibbsExp ((n : έΕζ) ┬╖ ╬▓) H = (gibbsExp ╬▓ H)^n`
  for `n : έΕΧ`.
* `gibbsExp_inv`, `gibbsExp_intCast_mul` έΑΦ explicit matrix inverse
  `(gibbsExp ╬▓ H)έΒ╗┬╣ = gibbsExp (-╬▓) H` and the integer-power extension
  to `n : έΕν`.
-/

namespace LatticeSystem.Quantum

open Matrix

variable {╬δ : Type*} [Fintype ╬δ] [DecidableEq ╬δ]

/-- Negation of a real cast to `έΕΓ` is self-adjoint. -/
private lemma negReal_isSelfAdjoint (╬▓ : έΕζ) : IsSelfAdjoint (-(╬▓ : έΕΓ)) := by
  rw [IsSelfAdjoint, star_neg, RCLike.star_def, Complex.conj_ofReal]

/-! ## Gibbs exponential -/

/-- The Gibbs exponential `exp(-╬▓ H)` for inverse temperature `╬▓ : έΕζ`
and Hamiltonian `H : ManyBodyOp ╬δ`. -/
noncomputable def gibbsExp (╬▓ : έΕζ) (H : ManyBodyOp ╬δ) : ManyBodyOp ╬δ :=
  NormedSpace.exp ((-(╬▓ : έΕΓ)) έΑλ H)

/-- `exp(-╬▓ H)` is Hermitian when `H` is Hermitian. -/
theorem gibbsExp_isHermitian {H : ManyBodyOp ╬δ} (hH : H.IsHermitian) (╬▓ : έΕζ) :
    (gibbsExp ╬▓ H).IsHermitian := by
  exact Matrix.IsHermitian.exp (hH.smul (negReal_isSelfAdjoint ╬▓))

/-! ## Partition function -/

/-- The partition function `Z(╬▓) = Tr(exp(-╬▓ H))`. -/
noncomputable def partitionFn (╬▓ : έΕζ) (H : ManyBodyOp ╬δ) : έΕΓ :=
  (gibbsExp ╬▓ H).trace

/-! ## Gibbs state (density matrix)

Note: `partitionFn ╬▓ H έΚι 0` (the partition function is nonzero) is
NOT proved here because the CFC-based proof
(`IsSelfAdjoint.exp_nonneg` under `open scoped MatrixOrder` +
`PosSemidef.trace_eq_zero_iff` + `Matrix.isUnit_exp`) causes
deterministic timeout in Lean's typeclass resolution. All downstream
theorems take `hZ : partitionFn ╬▓ H έΚι 0` as an explicit hypothesis. -/

/-- The Gibbs state (density matrix) `╧Β_╬▓ = (1/Z) exp(-╬▓ H)`. -/
noncomputable def gibbsState (╬▓ : έΕζ) (H : ManyBodyOp ╬δ) : ManyBodyOp ╬δ :=
  (1 / partitionFn ╬▓ H) έΑλ gibbsExp ╬▓ H

/-- The Gibbs state has unit trace: `Tr(╧Β_╬▓) = 1`. -/
theorem gibbsState_trace {H : ManyBodyOp ╬δ} (╬▓ : έΕζ)
    (hZ : partitionFn ╬▓ H έΚι 0) :
    (gibbsState ╬▓ H).trace = 1 := by
  simp only [gibbsState, Matrix.trace_smul, smul_eq_mul, one_div]
  exact inv_mul_cancelέΓΑ hZ

/-- The Gibbs state is Hermitian. -/
theorem gibbsState_isHermitian {H : ManyBodyOp ╬δ} (hH : H.IsHermitian) (╬▓ : έΕζ) :
    (gibbsState ╬▓ H).IsHermitian := by
  apply Matrix.IsHermitian.smul (gibbsExp_isHermitian hH ╬▓)
  have htr : star (partitionFn ╬▓ H) = partitionFn ╬▓ H := by
    simp only [partitionFn, έΗΡ Matrix.trace_conjTranspose, (gibbsExp_isHermitian hH ╬▓).eq]
  rw [IsSelfAdjoint, one_div, star_invέΓΑ, htr]

/-! ## Expectation value -/

/-- The Gibbs expectation value `έθρOέθσ_╬▓ = Tr(╧Β_╬▓ O)`. -/
noncomputable def gibbsExpectation (╬▓ : έΕζ) (H O : ManyBodyOp ╬δ) : έΕΓ :=
  ((gibbsState ╬▓ H) * O).trace

/-- `έθρ1έθσ_╬▓ = 1`. -/
theorem gibbsExpectation_one {H : ManyBodyOp ╬δ} (╬▓ : έΕζ)
    (hZ : partitionFn ╬▓ H έΚι 0) :
    gibbsExpectation ╬▓ H 1 = 1 := by
  simp only [gibbsExpectation, mul_one]
  exact gibbsState_trace ╬▓ hZ

/-! ## Properties at ╬▓ = 0 -/

/-- At `╬▓ = 0`, `exp(-0 ┬╖ H) = 1` (the identity matrix). -/
theorem gibbsExp_zero (H : ManyBodyOp ╬δ) : gibbsExp 0 H = 1 := by
  simp only [gibbsExp, neg_zero, Complex.ofReal_zero, zero_smul, NormedSpace.exp_zero]

/-! ## One-parameter group property in `╬▓` -/

/-- The Gibbs exponential is additive in the inverse temperature:
`gibbsExp (╬▓έΓΒ + ╬▓έΓΓ) H = gibbsExp ╬▓έΓΒ H * gibbsExp ╬▓έΓΓ H`. The two factors
commute because both are functions of the same `H`. -/
theorem gibbsExp_add (╬▓έΓΒ ╬▓έΓΓ : έΕζ) (H : ManyBodyOp ╬δ) :
    gibbsExp (╬▓έΓΒ + ╬▓έΓΓ) H = gibbsExp ╬▓έΓΒ H * gibbsExp ╬▓έΓΓ H := by
  unfold gibbsExp
  have hcomm : Commute (-(╬▓έΓΒ : έΕΓ) έΑλ H) (-(╬▓έΓΓ : έΕΓ) έΑλ H) :=
    ((Commute.refl H).smul_left _).smul_right _
  have hsum : -((╬▓έΓΒ + ╬▓έΓΓ : έΕζ) : έΕΓ) έΑλ H = -(╬▓έΓΒ : έΕΓ) έΑλ H + -(╬▓έΓΓ : έΕΓ) έΑλ H := by
    push_cast; module
  rw [hsum, Matrix.exp_add_of_commute _ _ hcomm]

/-- For commuting Hamiltonians `HέΓΒ, HέΓΓ`, the Gibbs exponential
factorises: `e^{-╬▓(HέΓΒ+HέΓΓ)} = e^{-╬▓HέΓΒ} ┬╖ e^{-╬▓HέΓΓ}`. This is the basic
identity behind exact decoupling, mean-field block decompositions, and
the simplest cases of the SuzukiέΑΥTrotter formula (where the
commutator-correction terms vanish). -/
theorem gibbsExp_add_of_commute_hamiltonians (╬▓ : έΕζ)
    {HέΓΒ HέΓΓ : ManyBodyOp ╬δ} (h : Commute HέΓΒ HέΓΓ) :
    gibbsExp ╬▓ (HέΓΒ + HέΓΓ) = gibbsExp ╬▓ HέΓΒ * gibbsExp ╬▓ HέΓΓ := by
  unfold gibbsExp
  have hcomm : Commute (-(╬▓ : έΕΓ) έΑλ HέΓΒ) (-(╬▓ : έΕΓ) έΑλ HέΓΓ) :=
    (h.smul_left _).smul_right _
  rw [smul_add, Matrix.exp_add_of_commute _ _ hcomm]

/-- `exp(╬▓H) ┬╖ exp(-╬▓H) = 1`: the Gibbs exponential at `-╬▓` is a left
inverse of the one at `╬▓`. -/
theorem gibbsExp_neg_mul_self (╬▓ : έΕζ) (H : ManyBodyOp ╬δ) :
    gibbsExp (-╬▓) H * gibbsExp ╬▓ H = 1 := by
  rw [έΗΡ gibbsExp_add, neg_add_cancel, gibbsExp_zero]

/-- `exp(-╬▓H) ┬╖ exp(╬▓H) = 1`: the Gibbs exponential at `╬▓` is a left
inverse of the one at `-╬▓`. -/
theorem gibbsExp_self_mul_neg (╬▓ : έΕζ) (H : ManyBodyOp ╬δ) :
    gibbsExp ╬▓ H * gibbsExp (-╬▓) H = 1 := by
  rw [έΗΡ gibbsExp_add, add_neg_cancel, gibbsExp_zero]

/-- The Gibbs exponential is a unit (invertible) for every `╬▓` and `H`. -/
theorem gibbsExp_isUnit (╬▓ : έΕζ) (H : ManyBodyOp ╬δ) :
    IsUnit (gibbsExp ╬▓ H) :=
  IsUnit.of_mul_eq_one _ (gibbsExp_self_mul_neg ╬▓ H)

/-- The Gibbs exponential is nonzero. Direct corollary of
`gibbsExp_isUnit` via `IsUnit.ne_zero`. -/
theorem gibbsExp_ne_zero (╬▓ : έΕζ) (H : ManyBodyOp ╬δ) :
    gibbsExp ╬▓ H έΚι 0 :=
  (gibbsExp_isUnit ╬▓ H).ne_zero

/-- The Gibbs state is nonzero whenever the partition function is.
Follows from `gibbsExp_ne_zero` and nonzero scalar multiplication. -/
theorem gibbsState_ne_zero {H : ManyBodyOp ╬δ} (╬▓ : έΕζ)
    (hZ : partitionFn ╬▓ H έΚι 0) :
    gibbsState ╬▓ H έΚι 0 := by
  unfold gibbsState
  exact smul_ne_zero (one_div_ne_zero hZ) (gibbsExp_ne_zero ╬▓ H)

/-- Explicit matrix inverse of the Gibbs state when the partition function
is nonzero: `(╧Β_╬▓)έΒ╗┬╣ = Z(╬▓) ┬╖ e^{╬▓ H}`. Note that
`gibbsExp (-╬▓) H = e^{╬▓ H}` in our convention. -/
theorem gibbsState_inv {H : ManyBodyOp ╬δ} (╬▓ : έΕζ)
    (hZ : partitionFn ╬▓ H έΚι 0) :
    (gibbsState ╬▓ H)έΒ╗┬╣ = partitionFn ╬▓ H έΑλ gibbsExp (-╬▓) H := by
  unfold gibbsState
  apply Matrix.inv_eq_left_inv
  rw [smul_mul_smul_comm, gibbsExp_neg_mul_self, mul_one_div_cancel hZ, one_smul]

/-- Canonical rescaled identity: when `Z(╬▓) έΚι 0`,
`Z(╬▓) ┬╖ ╧Β_╬▓ = e^{-╬▓ H}`. Inverts the defining relation
`╧Β_╬▓ = (1/Z) ┬╖ e^{-╬▓ H}` to express the Gibbs exponential as the
partition function times the density matrix. -/
theorem partitionFn_smul_gibbsState_eq_gibbsExp {H : ManyBodyOp ╬δ} (╬▓ : έΕζ)
    (hZ : partitionFn ╬▓ H έΚι 0) :
    partitionFn ╬▓ H έΑλ gibbsState ╬▓ H = gibbsExp ╬▓ H := by
  unfold gibbsState
  rw [smul_smul, mul_one_div_cancel hZ, one_smul]

/-- Canonical normalisation identity: when `Z(╬▓) έΚι 0`,
`Z(╬▓) ┬╖ έθρAέθσ_╬▓ = Tr(e^{-╬▓ H} ┬╖ A)`. The "unnormalised" expectation on
the right is the form that appears throughout canonical-ensemble
derivations. -/
theorem partitionFn_mul_gibbsExpectation_eq {H : ManyBodyOp ╬δ} (╬▓ : έΕζ)
    (hZ : partitionFn ╬▓ H έΚι 0) (A : ManyBodyOp ╬δ) :
    partitionFn ╬▓ H * gibbsExpectation ╬▓ H A = (gibbsExp ╬▓ H * A).trace := by
  unfold gibbsExpectation
  calc partitionFn ╬▓ H * (gibbsState ╬▓ H * A).trace
      = (partitionFn ╬▓ H έΑλ (gibbsState ╬▓ H * A)).trace := by
        rw [Matrix.trace_smul, smul_eq_mul]
    _ = ((partitionFn ╬▓ H έΑλ gibbsState ╬▓ H) * A).trace := by
        rw [Matrix.smul_mul]
    _ = (gibbsExp ╬▓ H * A).trace := by
        rw [partitionFn_smul_gibbsState_eq_gibbsExp ╬▓ hZ]

/-- Exact discrete semigroup identity: for `n : έΕΧ`,
`gibbsExp ((n : έΕζ) * ╬▓) H = (gibbsExp ╬▓ H) ^ n`. -/
theorem gibbsExp_natCast_mul (n : έΕΧ) (╬▓ : έΕζ) (H : ManyBodyOp ╬δ) :
    gibbsExp ((n : έΕζ) * ╬▓) H = (gibbsExp ╬▓ H) ^ n := by
  induction n with
  | zero => simp [gibbsExp_zero]
  | succ k ih =>
    have hsplit : ((k + 1 : έΕΧ) : έΕζ) * ╬▓ = (k : έΕζ) * ╬▓ + ╬▓ := by push_cast; ring
    rw [hsplit, gibbsExp_add, ih, pow_succ]

/-- Specialisation at `n = 2`:
`gibbsExp (2╬▓) H = gibbsExp ╬▓ H ┬╖ gibbsExp ╬▓ H`. -/
theorem gibbsExp_two_mul (╬▓ : έΕζ) (H : ManyBodyOp ╬δ) :
    gibbsExp (2 * ╬▓) H = gibbsExp ╬▓ H * gibbsExp ╬▓ H := by
  have := gibbsExp_natCast_mul 2 ╬▓ H
  simpa [pow_two] using this

/-- The matrix inverse of `gibbsExp ╬▓ H` is `gibbsExp (-╬▓) H`,
making the inverse provided abstractly by `gibbsExp_isUnit` explicit. -/
theorem gibbsExp_inv (╬▓ : έΕζ) (H : ManyBodyOp ╬δ) :
    (gibbsExp ╬▓ H)έΒ╗┬╣ = gibbsExp (-╬▓) H :=
  Matrix.inv_eq_left_inv (gibbsExp_neg_mul_self ╬▓ H)

/-- Integer-power identity: for `n : έΕν`,
`gibbsExp ((n : έΕζ) * ╬▓) H = (gibbsExp ╬▓ H) ^ n`. Extends
`gibbsExp_natCast_mul` to negative powers using `gibbsExp_inv`. -/
theorem gibbsExp_intCast_mul (n : έΕν) (╬▓ : έΕζ) (H : ManyBodyOp ╬δ) :
    gibbsExp ((n : έΕζ) * ╬▓) H = (gibbsExp ╬▓ H) ^ n := by
  obtain έθρm, rfl | rflέθσ := n.eq_nat_or_neg
  ┬╖ push_cast
    rw [zpow_natCast, gibbsExp_natCast_mul]
  ┬╖ have hM : IsUnit (gibbsExp ╬▓ H).det :=
      (Matrix.isUnit_iff_isUnit_det _).mp (gibbsExp_isUnit ╬▓ H)
    push_cast
    rw [Matrix.zpow_neg hM, zpow_natCast,
        show -((m : έΕζ)) * ╬▓ = -((m : έΕζ) * ╬▓) from by ring,
        έΗΡ gibbsExp_inv ((m : έΕζ) * ╬▓) H,
        gibbsExp_natCast_mul]

/-- At `╬▓ = 0`, the partition function equals the dimension of the
Hilbert space: `Z(0) = |╬δ έΗΤ Fin 2|`. -/
theorem partitionFn_zero (H : ManyBodyOp ╬δ) :
    partitionFn 0 H = Fintype.card (╬δ έΗΤ Fin 2) := by
  simp only [partitionFn, gibbsExp_zero, Matrix.trace_one]

/-- The partition function at `╬▓ = 0` is nonzero (the dimension is positive).
The configuration space `╬δ έΗΤ Fin 2` is automatically nonempty since
`Fin 2` is nonempty, so no extra hypothesis is needed. -/
theorem partitionFn_zero_ne_zero (H : ManyBodyOp ╬δ) :
    partitionFn 0 H έΚι 0 := by
  rw [partitionFn_zero]
  exact_mod_cast Fintype.card_pos.ne'

/-- For any Hermitian matrix `A : Matrix n n έΕΓ`, the trace is real. -/
theorem _root_.Matrix.IsHermitian.trace_im
    {n : Type*} [Fintype n] {A : Matrix n n έΕΓ} (hA : A.IsHermitian) :
    A.trace.im = 0 := by
  have : star A.trace = A.trace := by
    rw [έΗΡ Matrix.trace_conjTranspose, hA.eq]
  exact Complex.conj_eq_iff_im.mp this

/-- For a Hermitian Hamiltonian `H`, the partition function
`Z(╬▓) = Tr(e^{-╬▓H})` is real. -/
theorem partitionFn_im_of_isHermitian {H : ManyBodyOp ╬δ}
    (hH : H.IsHermitian) (╬▓ : έΕζ) :
    (partitionFn ╬▓ H).im = 0 :=
  (gibbsExp_isHermitian hH ╬▓).trace_im

/-- The Gibbs state purity equals `Z(2╬▓) / Z(╬▓)┬▓`:
`Tr(╧Β_╬▓┬▓) = partitionFn (2 ╬▓) H / (partitionFn ╬▓ H)┬▓`. The "purity"
measure of the canonical density matrix; equal to 1 for pure states,
less than 1 for mixed states. The `Z = 0` edge case is handled by
Lean's `1/0 = 0` convention: both sides collapse to zero. -/
theorem gibbsState_mul_self_trace (╬▓ : έΕζ) (H : ManyBodyOp ╬δ) :
    (gibbsState ╬▓ H * gibbsState ╬▓ H).trace
      = partitionFn (2 * ╬▓) H / (partitionFn ╬▓ H) ^ 2 := by
  unfold gibbsState
  rw [Matrix.smul_mul, Matrix.mul_smul, smul_smul, έΗΡ gibbsExp_two_mul,
    Matrix.trace_smul, smul_eq_mul]
  unfold partitionFn
  field_simp

/-- The Gibbs state higher-moment trace identity:
`Tr(╧Β_╬▓^n) = Z(n╬▓) / Z(╬▓)^n` for any `n : έΕΧ`. The R├σnyi-n entropy
precursor; expresses the trace of the n-th power of the density matrix
entirely in terms of partition functions evaluated at temperature `n ╬▓`.

Edge cases: at `n = 0`, both sides equal `Tr(1) = dim`. At `Z = 0`,
the identity holds by Lean's `1/0 = 0` convention (both sides
collapse to zero for `n έΚξ 1`). -/
theorem gibbsState_pow_trace (╬▓ : έΕζ) (H : ManyBodyOp ╬δ) (n : έΕΧ) :
    ((gibbsState ╬▓ H) ^ n).trace
      = partitionFn ((n : έΕζ) * ╬▓) H / (partitionFn ╬▓ H) ^ n := by
  unfold gibbsState partitionFn
  rw [smul_pow, έΗΡ gibbsExp_natCast_mul, Matrix.trace_smul, smul_eq_mul,
    one_div, inv_pow, div_eq_inv_mul]

/-- At `╬▓ = 0`, the Gibbs state is the maximally mixed state
`╧Β_0 = (1 / dim) ┬╖ I`. -/
theorem gibbsState_zero (H : ManyBodyOp ╬δ) :
    gibbsState 0 H = ((Fintype.card (╬δ έΗΤ Fin 2) : έΕΓ))έΒ╗┬╣ έΑλ (1 : ManyBodyOp ╬δ) := by
  simp only [gibbsState, gibbsExp_zero, partitionFn_zero, one_div]

/-- At `╬▓ = 0`, the matrix inverse of the Gibbs state is the dimension
times the identity: `╧Β_0έΒ╗┬╣ = dim ┬╖ I`. -/
theorem gibbsState_zero_inv (H : ManyBodyOp ╬δ) :
    (gibbsState 0 H)έΒ╗┬╣ =
      (Fintype.card (╬δ έΗΤ Fin 2) : έΕΓ) έΑλ (1 : ManyBodyOp ╬δ) := by
  rw [gibbsState_zero]
  apply Matrix.inv_eq_left_inv
  rw [smul_mul_smul_comm, mul_inv_cancelέΓΑ, Matrix.one_mul, one_smul]
  exact_mod_cast Fintype.card_pos.ne'

/-- At `╬▓ = 0`, the Gibbs expectation reduces to the normalised trace
`έθρAέθσ_0 = (1 / dim) ┬╖ Tr(A)`. -/
theorem gibbsExpectation_zero (H A : ManyBodyOp ╬δ) :
    gibbsExpectation 0 H A = ((Fintype.card (╬δ έΗΤ Fin 2) : έΕΓ))έΒ╗┬╣ * A.trace := by
  simp only [gibbsExpectation, gibbsState_zero, Matrix.smul_mul, Matrix.one_mul,
    Matrix.trace_smul, smul_eq_mul]

/-! ## Linearity of expectation -/

/-- Expectation is additive: `έθρOέΓΒ + OέΓΓέθσ = έθρOέΓΒέθσ + έθρOέΓΓέθσ`. -/
theorem gibbsExpectation_add {H : ManyBodyOp ╬δ} (╬▓ : έΕζ) (OέΓΒ OέΓΓ : ManyBodyOp ╬δ) :
    gibbsExpectation ╬▓ H (OέΓΒ + OέΓΓ) = gibbsExpectation ╬▓ H OέΓΒ + gibbsExpectation ╬▓ H OέΓΓ := by
  simp only [gibbsExpectation, mul_add, Matrix.trace_add]

/-- Expectation is homogeneous: `έθρc έΑλ Oέθσ = c έΑλ έθρOέθσ`. -/
theorem gibbsExpectation_smul {H : ManyBodyOp ╬δ} (╬▓ : έΕζ) (c : έΕΓ) (O : ManyBodyOp ╬δ) :
    gibbsExpectation ╬▓ H (c έΑλ O) = c * gibbsExpectation ╬▓ H O := by
  simp only [gibbsExpectation, Matrix.mul_smul, Matrix.trace_smul, smul_eq_mul]

/-- Expectation negates with the observable: `έθρ-Oέθσ = -έθρOέθσ`. -/
theorem gibbsExpectation_neg {H : ManyBodyOp ╬δ} (╬▓ : έΕζ) (O : ManyBodyOp ╬δ) :
    gibbsExpectation ╬▓ H (-O) = -gibbsExpectation ╬▓ H O := by
  simp only [gibbsExpectation, Matrix.mul_neg, Matrix.trace_neg]

/-- Expectation distributes over subtraction: `έθρA - Bέθσ = έθρAέθσ - έθρBέθσ`. -/
theorem gibbsExpectation_sub {H : ManyBodyOp ╬δ} (╬▓ : έΕζ) (A B : ManyBodyOp ╬δ) :
    gibbsExpectation ╬▓ H (A - B) = gibbsExpectation ╬▓ H A - gibbsExpectation ╬▓ H B := by
  rw [sub_eq_add_neg, gibbsExpectation_add, gibbsExpectation_neg, sub_eq_add_neg]

/-- Expectation distributes over a finite sum:
`έθρέΙΣ i έΙΙ s, f iέθσ = έΙΣ i έΙΙ s, έθρf iέθσ`. -/
theorem gibbsExpectation_sum {H : ManyBodyOp ╬δ} (╬▓ : έΕζ) {╬╣ : Type*}
    (s : Finset ╬╣) (f : ╬╣ έΗΤ ManyBodyOp ╬δ) :
    gibbsExpectation ╬▓ H (έΙΣ i έΙΙ s, f i) = έΙΣ i έΙΙ s, gibbsExpectation ╬▓ H (f i) := by
  classical
  induction s using Finset.induction_on with
  | empty =>
    simp only [Finset.sum_empty, gibbsExpectation, Matrix.mul_zero, Matrix.trace_zero]
  | @insert a t hat ih =>
    rw [Finset.sum_insert hat, gibbsExpectation_add, ih, Finset.sum_insert hat]

/-! ## Commutativity of the Gibbs state with `H`

The density matrix `╧Β_╬▓ = exp(-╬▓ H)/Z` is a function of `H` (a power
series in `H`), hence commutes with `H`. Equivalently, `╧Β_╬▓` is
stationary under the unitary dynamics generated by `H`. See Tasaki
┬π3.3, p. 80. -/

/-- The Gibbs exponential commutes with the Hamiltonian:
`exp(-╬▓ H) ┬╖ H = H ┬╖ exp(-╬▓ H)`. -/
theorem gibbsExp_commute_hamiltonian (╬▓ : έΕζ) (H : ManyBodyOp ╬δ) :
    Commute (gibbsExp ╬▓ H) H := by
  unfold gibbsExp
  exact (((Commute.refl H).smul_left (-(╬▓ : έΕΓ))).exp_left)

/-- The Gibbs state commutes with the Hamiltonian: `╧Β_╬▓ ┬╖ H = H ┬╖ ╧Β_╬▓`. -/
theorem gibbsState_commute_hamiltonian (╬▓ : έΕζ) (H : ManyBodyOp ╬δ) :
    Commute (gibbsState ╬▓ H) H := by
  unfold gibbsState
  exact (gibbsExp_commute_hamiltonian ╬▓ H).smul_left _

/-! ## Reality of expectation for Hermitian observables

For a Hermitian Hamiltonian `H` and Hermitian observable `O`, the
expectation `έθρOέθσ_╬▓ = Tr(╧Β_╬▓ O)` is real:
`star έθρOέθσ_╬▓ = Tr((╧Β_╬▓ O)ά┤┤) = Tr(Oά┤┤ ╧Β_╬▓ ά┤┤) = Tr(O ╧Β_╬▓) = Tr(╧Β_╬▓ O)
            = έθρOέθσ_╬▓`,
combining `Matrix.trace_conjTranspose`, Hermiticity of `╧Β_╬▓` and `O`,
and the cyclic property `Matrix.trace_mul_comm`. See Tasaki ┬π3.3, p. 80. -/

/-- For Hermitian matrices `A`, `B` over `έΕΓ`, the trace `Tr(A ┬╖ B)`
is invariant under complex conjugation. This is the algebraic core of
the reality of Gibbs expectations and is independent of the Gibbs
construction. -/
theorem _root_.Matrix.trace_mul_star_of_isHermitian
    {n : Type*} [Fintype n] {A B : Matrix n n έΕΓ}
    (hA : A.IsHermitian) (hB : B.IsHermitian) :
    star (A * B).trace = (A * B).trace := by
  rw [έΗΡ Matrix.trace_conjTranspose, Matrix.conjTranspose_mul, hB.eq, hA.eq,
    Matrix.trace_mul_comm]

/-- For Hermitian `H` and Hermitian observable `O`, the Gibbs expectation
is invariant under complex conjugation, i.e. `star έθρOέθσ_╬▓ = έθρOέθσ_╬▓`. -/
theorem gibbsExpectation_star_of_isHermitian {H O : ManyBodyOp ╬δ}
    (hH : H.IsHermitian) (hO : O.IsHermitian) (╬▓ : έΕζ) :
    star (gibbsExpectation ╬▓ H O) = gibbsExpectation ╬▓ H O :=
  Matrix.trace_mul_star_of_isHermitian (gibbsState_isHermitian hH ╬▓) hO

/-- For Hermitian `H` and Hermitian observable `O`, the imaginary part of
the Gibbs expectation vanishes: `(έθρOέθσ_╬▓).im = 0`. -/
theorem gibbsExpectation_im_of_isHermitian {H O : ManyBodyOp ╬δ}
    (hH : H.IsHermitian) (hO : O.IsHermitian) (╬▓ : έΕζ) :
    (gibbsExpectation ╬▓ H O).im = 0 :=
  Complex.conj_eq_iff_im.mp (gibbsExpectation_star_of_isHermitian hH hO ╬▓)

/-- For Hermitian `H` and Hermitian observable `O`, the Gibbs expectation
equals the complex embedding of its real part:
`((έθρOέθσ_╬▓).re : έΕΓ) = έθρOέθσ_╬▓`. The imaginary part vanishes by
`gibbsExpectation_im_of_isHermitian`; `Complex.ext` then reduces
the goal to its real and imaginary components, both discharged
by `simp` after rewriting with the realness hypothesis. -/
theorem gibbsExpectation_ofReal_re_eq_of_isHermitian {H O : ManyBodyOp ╬δ}
    (hH : H.IsHermitian) (hO : O.IsHermitian) (╬▓ : έΕζ) :
    ((gibbsExpectation ╬▓ H O).re : έΕΓ) = gibbsExpectation ╬▓ H O := by
  have him := gibbsExpectation_im_of_isHermitian hH hO ╬▓
  apply Complex.ext <;> simp [him]

/-! ## Conservation laws

Since `[╧Β_╬▓, H] = 0`, the Gibbs expectation of any commutator with the
Hamiltonian vanishes:

  `έθρ[H, A]έθσ_╬▓ = Tr(╧Β (HA - AH)) = Tr(H╧Β A) - Tr(╧Β AH)
              = Tr(╧Β AH) - Tr(╧Β AH) = 0`,

using `gibbsState_commute_hamiltonian` and the cyclic property of the
trace `Matrix.trace_mul_comm`. Equivalently, `έθρHAέθσ_╬▓ = έθρAHέθσ_╬▓` for any
observable `A`. See Tasaki ┬π3.3, p. 80. -/

/-- The Hamiltonian and any observable can be exchanged inside the
Gibbs expectation: `έθρH ┬╖ Aέθσ_╬▓ = έθρA ┬╖ Hέθσ_╬▓`. -/
theorem gibbsExpectation_mul_hamiltonian_comm (╬▓ : έΕζ) (H A : ManyBodyOp ╬δ) :
    gibbsExpectation ╬▓ H (H * A) = gibbsExpectation ╬▓ H (A * H) := by
  unfold gibbsExpectation
  rw [έΗΡ Matrix.mul_assoc, (gibbsState_commute_hamiltonian ╬▓ H).eq,
    Matrix.mul_assoc, Matrix.trace_mul_comm, Matrix.mul_assoc]

/-- Generalisation of `gibbsExpectation_mul_hamiltonian_comm` to any
conserved quantity `A`: when `[A, H] = 0`, `έθρA ┬╖ Oέθσ_╬▓ = έθρO ┬╖ Aέθσ_╬▓`
for any observable `O`. The Gibbs state inherits the commutativity:
`A` commutes with `gibbsExp ╬▓ H` (via `Commute.exp_right`), and a
fortiori with `gibbsState ╬▓ H = (1/Z) έΑλ gibbsExp ╬▓ H`. -/
theorem gibbsExpectation_mul_comm_of_commute_hamiltonian (╬▓ : έΕζ)
    {H A : ManyBodyOp ╬δ} (hA : Commute A H) (O : ManyBodyOp ╬δ) :
    gibbsExpectation ╬▓ H (A * O) = gibbsExpectation ╬▓ H (O * A) := by
  have h╧Β : Commute A (gibbsState ╬▓ H) :=
    ((hA.smul_right (-(╬▓ : έΕΓ))).exp_right).smul_right _
  unfold gibbsExpectation
  rw [έΗΡ Matrix.mul_assoc, h╧Β.eq.symm, Matrix.mul_assoc,
    Matrix.trace_mul_comm, Matrix.mul_assoc]

/-- The Gibbs expectation of any commutator with the Hamiltonian vanishes:
`έθρ[H, A]έθσ_╬▓ = 0`. -/
theorem gibbsExpectation_commutator_hamiltonian (╬▓ : έΕζ) (H A : ManyBodyOp ╬δ) :
    gibbsExpectation ╬▓ H (H * A - A * H) = 0 := by
  rw [sub_eq_add_neg, έΗΡ neg_one_smul έΕΓ (A * H), gibbsExpectation_add,
    gibbsExpectation_smul, gibbsExpectation_mul_hamiltonian_comm]
  ring

/-- For a Hermitian Hamiltonian `H`, the energy expectation `έθρHέθσ_╬▓` is real. -/
theorem gibbsExpectation_hamiltonian_im {H : ManyBodyOp ╬δ}
    (hH : H.IsHermitian) (╬▓ : έΕζ) :
    (gibbsExpectation ╬▓ H H).im = 0 :=
  gibbsExpectation_im_of_isHermitian hH hH ╬▓

/-- For Hermitian `H` and Hermitian observable `O`, the second-moment
expectation `έθρO ┬╖ Oέθσ_╬▓` is real. The product `O ┬╖ O` is Hermitian
because `O` commutes with itself; the result then specialises
`gibbsExpectation_im_of_isHermitian`. -/
theorem gibbsExpectation_sq_im_of_isHermitian {H O : ManyBodyOp ╬δ}
    (hH : H.IsHermitian) (hO : O.IsHermitian) (╬▓ : έΕζ) :
    (gibbsExpectation ╬▓ H (O * O)).im = 0 :=
  gibbsExpectation_im_of_isHermitian hH
    (Matrix.IsHermitian.mul_of_commute hO hO (Commute.refl O)) ╬▓

/-- For Hermitian `H`, Hermitian `O`, and any `n : έΕΧ`,
`(έθρO ^ nέθσ_╬▓).im = 0`. Generalises `gibbsExpectation_sq_im_of_isHermitian`
to arbitrary natural powers via `Matrix.IsHermitian.pow`. -/
theorem gibbsExpectation_pow_im_of_isHermitian {H O : ManyBodyOp ╬δ}
    (hH : H.IsHermitian) (hO : O.IsHermitian) (╬▓ : έΕζ) (n : έΕΧ) :
    (gibbsExpectation ╬▓ H (O ^ n)).im = 0 :=
  gibbsExpectation_im_of_isHermitian hH (hO.pow n) ╬▓

/-! ## Variance -/

/-- The canonical-ensemble variance of an observable `O` at inverse
temperature `╬▓` under Hamiltonian `H`:
`Var_╬▓(O) := έθρO┬▓έθσ_╬▓ έΙΤ (έθρOέθσ_╬▓)┬▓`. -/
noncomputable def gibbsVariance (╬▓ : έΕζ) (H O : ManyBodyOp ╬δ) : έΕΓ :=
  gibbsExpectation ╬▓ H (O * O) - (gibbsExpectation ╬▓ H O) ^ 2

/-- Unfolding lemma: `Var_╬▓(O) = έθρO ┬╖ Oέθσ_╬▓ έΙΤ έθρOέθσ_╬▓┬▓`. -/
theorem gibbsVariance_eq (╬▓ : έΕζ) (H O : ManyBodyOp ╬δ) :
    gibbsVariance ╬▓ H O =
      gibbsExpectation ╬▓ H (O * O) - (gibbsExpectation ╬▓ H O) ^ 2 :=
  rfl

/-- For Hermitian Gibbs `H` and Hermitian observable `O`, the variance
is real. The second moment is real by `gibbsExpectation_sq_im_of_isHermitian`,
the squared first moment by squaring a real complex number, and the
difference of two reals is real. -/
theorem gibbsVariance_im_of_isHermitian {H O : ManyBodyOp ╬δ}
    (hH : H.IsHermitian) (hO : O.IsHermitian) (╬▓ : έΕζ) :
    (gibbsVariance ╬▓ H O).im = 0 := by
  unfold gibbsVariance
  have h1 : (gibbsExpectation ╬▓ H (O * O)).im = 0 :=
    gibbsExpectation_sq_im_of_isHermitian hH hO ╬▓
  have h2 : (gibbsExpectation ╬▓ H O).im = 0 :=
    gibbsExpectation_im_of_isHermitian hH hO ╬▓
  have h2sq : ((gibbsExpectation ╬▓ H O) ^ 2).im = 0 := by
    rw [pow_two, Complex.mul_im, h2, zero_mul, mul_zero, add_zero]
  rw [Complex.sub_im, h1, h2sq, sub_zero]

/-- At `╬▓ = 0`, the variance reduces to the normalised-trace formula
`Var_0(O) = (1/dim) ┬╖ Tr(O┬▓) έΙΤ ((1/dim) ┬╖ Tr O)┬▓`. -/
theorem gibbsVariance_zero (H O : ManyBodyOp ╬δ) :
    gibbsVariance 0 H O =
      ((Fintype.card (╬δ έΗΤ Fin 2) : έΕΓ))έΒ╗┬╣ * (O * O).trace
        - (((Fintype.card (╬δ έΗΤ Fin 2) : έΕΓ))έΒ╗┬╣ * O.trace) ^ 2 := by
  unfold gibbsVariance
  rw [gibbsExpectation_zero, gibbsExpectation_zero]

/-- The variance equals the second moment of the centered observable
`├Φ := O έΙΤ έθρOέθσ ┬╖ 1`:
`Var_╬▓(O) = έθρ(O έΙΤ έθρOέθσ_╬▓ ┬╖ 1) ┬╖ (O έΙΤ έθρOέθσ_╬▓ ┬╖ 1)έθσ_╬▓` (when `Z(╬▓) έΚι 0`). -/
theorem gibbsVariance_eq_centered_sq {H O : ManyBodyOp ╬δ} (╬▓ : έΕζ)
    (hZ : partitionFn ╬▓ H έΚι 0) :
    gibbsExpectation ╬▓ H ((O - (gibbsExpectation ╬▓ H O) έΑλ (1 : ManyBodyOp ╬δ)) *
        (O - (gibbsExpectation ╬▓ H O) έΑλ 1)) = gibbsVariance ╬▓ H O := by
  set c := gibbsExpectation ╬▓ H O with hc
  have hsq : (O - c έΑλ (1 : ManyBodyOp ╬δ)) * (O - c έΑλ 1) =
             O * O - c έΑλ O - c έΑλ O + (c * c) έΑλ (1 : ManyBodyOp ╬δ) := by
    simp only [sub_mul, mul_sub, Matrix.smul_mul, Matrix.mul_smul,
      Matrix.one_mul, Matrix.mul_one, smul_smul]
    abel
  rw [hsq]
  simp only [gibbsExpectation_add, gibbsExpectation_sub, gibbsExpectation_smul]
  rw [show gibbsExpectation ╬▓ H 1 = 1 from gibbsExpectation_one ╬▓ hZ]
  unfold gibbsVariance
  rw [pow_two, έΗΡ hc]
  ring

/-! ## Covariance -/

/-- The canonical-ensemble covariance of two observables `A`, `B` at
inverse temperature `╬▓` under Hamiltonian `H`:
`Cov_╬▓(A, B) := έθρA ┬╖ Bέθσ_╬▓ έΙΤ έθρAέθσ_╬▓ ┬╖ έθρBέθσ_╬▓`. -/
noncomputable def gibbsCovariance (╬▓ : έΕζ) (H A B : ManyBodyOp ╬δ) : έΕΓ :=
  gibbsExpectation ╬▓ H (A * B) - gibbsExpectation ╬▓ H A * gibbsExpectation ╬▓ H B

/-- Unfolding lemma:
`Cov_╬▓(A, B) = έθρA ┬╖ Bέθσ_╬▓ έΙΤ έθρAέθσ_╬▓ ┬╖ έθρBέθσ_╬▓`. -/
theorem gibbsCovariance_eq (╬▓ : έΕζ) (H A B : ManyBodyOp ╬δ) :
    gibbsCovariance ╬▓ H A B =
      gibbsExpectation ╬▓ H (A * B)
        - gibbsExpectation ╬▓ H A * gibbsExpectation ╬▓ H B :=
  rfl

/-- Self-covariance is the variance:
`Cov_╬▓(O, O) = Var_╬▓(O)`. -/
theorem gibbsCovariance_self_eq_variance (╬▓ : έΕζ) (H O : ManyBodyOp ╬δ) :
    gibbsCovariance ╬▓ H O O = gibbsVariance ╬▓ H O := by
  unfold gibbsCovariance gibbsVariance
  rw [pow_two]

/-- The antisymmetric part of the complex covariance equals the
commutator expectation:
`Cov_╬▓(A, B) έΙΤ Cov_╬▓(B, A) = έθρA ┬╖ B έΙΤ B ┬╖ Aέθσ_╬▓`.
The product terms `έθρAέθσ ┬╖ έθρBέθσ` cancel, isolating the noncommutativity
of `A` and `B`. -/
theorem gibbsCovariance_sub_swap_eq_commutator (╬▓ : έΕζ) (H A B : ManyBodyOp ╬δ) :
    gibbsCovariance ╬▓ H A B - gibbsCovariance ╬▓ H B A
      = gibbsExpectation ╬▓ H (A * B - B * A) := by
  unfold gibbsCovariance
  rw [gibbsExpectation_sub]
  ring

/-! ### Bilinearity of the complex covariance -/

/-- Additivity in the left argument:
`Cov_╬▓(AέΓΒ + AέΓΓ, B) = Cov_╬▓(AέΓΒ, B) + Cov_╬▓(AέΓΓ, B)`. -/
theorem gibbsCovariance_add_left (╬▓ : έΕζ) (H AέΓΒ AέΓΓ B : ManyBodyOp ╬δ) :
    gibbsCovariance ╬▓ H (AέΓΒ + AέΓΓ) B
      = gibbsCovariance ╬▓ H AέΓΒ B + gibbsCovariance ╬▓ H AέΓΓ B := by
  unfold gibbsCovariance
  rw [add_mul, gibbsExpectation_add, gibbsExpectation_add]
  ring

/-- Additivity in the right argument:
`Cov_╬▓(A, BέΓΒ + BέΓΓ) = Cov_╬▓(A, BέΓΒ) + Cov_╬▓(A, BέΓΓ)`. -/
theorem gibbsCovariance_add_right (╬▓ : έΕζ) (H A BέΓΒ BέΓΓ : ManyBodyOp ╬δ) :
    gibbsCovariance ╬▓ H A (BέΓΒ + BέΓΓ)
      = gibbsCovariance ╬▓ H A BέΓΒ + gibbsCovariance ╬▓ H A BέΓΓ := by
  unfold gibbsCovariance
  rw [mul_add, gibbsExpectation_add, gibbsExpectation_add]
  ring

/-- Scalar pull-out from the left argument:
`Cov_╬▓(c έΑλ A, B) = c ┬╖ Cov_╬▓(A, B)`. -/
theorem gibbsCovariance_smul_left (╬▓ : έΕζ) (H : ManyBodyOp ╬δ) (c : έΕΓ)
    (A B : ManyBodyOp ╬δ) :
    gibbsCovariance ╬▓ H (c έΑλ A) B = c * gibbsCovariance ╬▓ H A B := by
  unfold gibbsCovariance
  rw [Matrix.smul_mul, gibbsExpectation_smul, gibbsExpectation_smul]
  ring

/-- Scalar pull-out from the right argument:
`Cov_╬▓(A, c έΑλ B) = c ┬╖ Cov_╬▓(A, B)`. -/
theorem gibbsCovariance_smul_right (╬▓ : έΕζ) (H A : ManyBodyOp ╬δ) (c : έΕΓ)
    (B : ManyBodyOp ╬δ) :
    gibbsCovariance ╬▓ H A (c έΑλ B) = c * gibbsCovariance ╬▓ H A B := by
  unfold gibbsCovariance
  rw [Matrix.mul_smul, gibbsExpectation_smul, gibbsExpectation_smul]
  ring

/-! #### Vanishing on constant-scalar arguments -/

/-- The complex covariance vanishes when its left argument is a scalar
multiple of the identity, provided `Z(╬▓) έΚι 0`. -/
theorem gibbsCovariance_const_smul_one_left_eq_zero {H : ManyBodyOp ╬δ} (╬▓ : έΕζ)
    (hZ : partitionFn ╬▓ H έΚι 0) (c : έΕΓ) (B : ManyBodyOp ╬δ) :
    gibbsCovariance ╬▓ H (c έΑλ (1 : ManyBodyOp ╬δ)) B = 0 := by
  unfold gibbsCovariance
  rw [Matrix.smul_mul, Matrix.one_mul, gibbsExpectation_smul,
    gibbsExpectation_smul, gibbsExpectation_one ╬▓ hZ, mul_one]
  ring

/-- The complex covariance vanishes when its right argument is a scalar
multiple of the identity, provided `Z(╬▓) έΚι 0`. -/
theorem gibbsCovariance_const_smul_one_right_eq_zero {H : ManyBodyOp ╬δ} (╬▓ : έΕζ)
    (hZ : partitionFn ╬▓ H έΚι 0) (A : ManyBodyOp ╬δ) (c : έΕΓ) :
    gibbsCovariance ╬▓ H A (c έΑλ (1 : ManyBodyOp ╬δ)) = 0 := by
  unfold gibbsCovariance
  rw [Matrix.mul_smul, Matrix.mul_one, gibbsExpectation_smul,
    gibbsExpectation_smul, gibbsExpectation_one ╬▓ hZ, mul_one]
  ring

/-! ## Anticommutator real, commutator purely imaginary

For Hermitian `╧Β` and arbitrary `X`,
  `star Tr(╧Β ┬╖ X) = Tr((╧Β ┬╖ X)ά┤┤) = Tr(Xά┤┤ ┬╖ ╧Β) = Tr(╧Β ┬╖ Xά┤┤)`,
combining `trace_conjTranspose`, `conjTranspose_mul`, Hermiticity of
`╧Β`, and the cyclic property `Matrix.trace_mul_comm`. Specialising
`X = A ┬╖ B` with `A, B` Hermitian gives
`star έθρA ┬╖ Bέθσ_╬▓ = έθρB ┬╖ Aέθσ_╬▓`. From this, `έθρA┬╖B + B┬╖Aέθσ_╬▓` (an "anti-
commutator") is `z + star z = 2┬╖Re z`, hence real, and `έθρA┬╖B έΙΤ B┬╖Aέθσ_╬▓`
is `z έΙΤ star z = 2 i┬╖Im z`, hence purely imaginary. -/

/-- For Hermitian `╧Β : Matrix n n έΕΓ` and arbitrary `X`,
`star Tr(╧Β ┬╖ X) = Tr(╧Β ┬╖ Xά┤┤)`. -/
theorem _root_.Matrix.trace_mul_conjTranspose_swap_of_isHermitian
    {n : Type*} [Fintype n] {╧Β : Matrix n n έΕΓ} (h╧Β : ╧Β.IsHermitian)
    (X : Matrix n n έΕΓ) :
    star (╧Β * X).trace = (╧Β * X.conjTranspose).trace := by
  rw [έΗΡ Matrix.trace_conjTranspose, Matrix.conjTranspose_mul, h╧Β.eq,
    Matrix.trace_mul_comm]

/-- For Hermitian `H` and Hermitian `A, B`,
`star έθρA ┬╖ Bέθσ_╬▓ = έθρB ┬╖ Aέθσ_╬▓`. -/
theorem gibbsExpectation_star_swap_of_isHermitian {H A B : ManyBodyOp ╬δ}
    (hH : H.IsHermitian) (hA : A.IsHermitian) (hB : B.IsHermitian) (╬▓ : έΕζ) :
    star (gibbsExpectation ╬▓ H (A * B)) = gibbsExpectation ╬▓ H (B * A) := by
  unfold gibbsExpectation
  rw [Matrix.trace_mul_conjTranspose_swap_of_isHermitian
        (gibbsState_isHermitian hH ╬▓) (A * B),
      Matrix.conjTranspose_mul, hA.eq, hB.eq]

/-- For Hermitian `H` and Hermitian `A, B`, the anticommutator
expectation `έθρA ┬╖ B + B ┬╖ Aέθσ_╬▓` is real. -/
theorem gibbsExpectation_anticommutator_im {H A B : ManyBodyOp ╬δ}
    (hH : H.IsHermitian) (hA : A.IsHermitian) (hB : B.IsHermitian) (╬▓ : έΕζ) :
    (gibbsExpectation ╬▓ H (A * B + B * A)).im = 0 := by
  rw [gibbsExpectation_add, έΗΡ gibbsExpectation_star_swap_of_isHermitian hH hA hB ╬▓,
    Complex.add_im, Complex.star_def, Complex.conj_im, add_neg_cancel]

/-- For Hermitian `H` and Hermitian `A, B`, the commutator expectation
`έθρA ┬╖ B έΙΤ B ┬╖ Aέθσ_╬▓` is purely imaginary. -/
theorem gibbsExpectation_commutator_re {H A B : ManyBodyOp ╬δ}
    (hH : H.IsHermitian) (hA : A.IsHermitian) (hB : B.IsHermitian) (╬▓ : έΕζ) :
    (gibbsExpectation ╬▓ H (A * B - B * A)).re = 0 := by
  rw [sub_eq_add_neg, έΗΡ neg_one_smul έΕΓ (B * A), gibbsExpectation_add,
    gibbsExpectation_smul,
    έΗΡ gibbsExpectation_star_swap_of_isHermitian hH hA hB ╬▓]
  simp [Complex.add_re, Complex.conj_re]

/-- For Hermitian `H` and Hermitian observable `O`,
`(έθρH ┬╖ Oέθσ_╬▓).im = 0`, i.e.\ the expectation of the (generally
non-Hermitian) product `H ┬╖ O` is real. -/
theorem gibbsExpectation_mul_hamiltonian_im {H O : ManyBodyOp ╬δ}
    (hH : H.IsHermitian) (hO : O.IsHermitian) (╬▓ : έΕζ) :
    (gibbsExpectation ╬▓ H (H * O)).im = 0 := by
  have hcomm := gibbsExpectation_mul_hamiltonian_comm ╬▓ H O
  have hstar := gibbsExpectation_star_swap_of_isHermitian hH hH hO ╬▓
  have : star (gibbsExpectation ╬▓ H (H * O)) = gibbsExpectation ╬▓ H (H * O) := by
    rw [hstar, έΗΡ hcomm]
  exact Complex.conj_eq_iff_im.mp this

/-! ## Symmetric covariance (real-valued for Hermitian observables) -/

/-- The symmetric (real-valued for Hermitian observables) canonical
covariance: `Cov^s_╬▓(A, B) := (1/2) ┬╖ έθρA ┬╖ B + B ┬╖ Aέθσ_╬▓ έΙΤ έθρAέθσ_╬▓ ┬╖ έθρBέθσ_╬▓`.
The complex covariance `gibbsCovariance` for non-commuting Hermitian
observables generally has a nonzero imaginary part; averaging over the
anticommutator restores realness. -/
noncomputable def gibbsCovarianceSymm (╬▓ : έΕζ) (H A B : ManyBodyOp ╬δ) : έΕΓ :=
  (2 : έΕΓ)έΒ╗┬╣ * gibbsExpectation ╬▓ H (A * B + B * A)
    - gibbsExpectation ╬▓ H A * gibbsExpectation ╬▓ H B

/-- Unfolding lemma:
`Cov^s_╬▓(A, B) = (1/2) ┬╖ έθρA ┬╖ B + B ┬╖ Aέθσ_╬▓ έΙΤ έθρAέθσ_╬▓ ┬╖ έθρBέθσ_╬▓`. -/
theorem gibbsCovarianceSymm_eq (╬▓ : έΕζ) (H A B : ManyBodyOp ╬δ) :
    gibbsCovarianceSymm ╬▓ H A B =
      (2 : έΕΓ)έΒ╗┬╣ * gibbsExpectation ╬▓ H (A * B + B * A)
        - gibbsExpectation ╬▓ H A * gibbsExpectation ╬▓ H B :=
  rfl

/-- Self symmetric-covariance is the variance:
`Cov^s_╬▓(O, O) = Var_╬▓(O)`. The anticommutator `O ┬╖ O + O ┬╖ O = 2(O ┬╖ O)`
collapses the (1/2) prefactor. -/
theorem gibbsCovarianceSymm_self_eq_variance (╬▓ : έΕζ) (H O : ManyBodyOp ╬δ) :
    gibbsCovarianceSymm ╬▓ H O O = gibbsVariance ╬▓ H O := by
  unfold gibbsCovarianceSymm gibbsVariance
  have h2 : O * O + O * O = (2 : έΕΓ) έΑλ (O * O) := by
    rw [two_smul]
  rw [h2, gibbsExpectation_smul, έΗΡ mul_assoc, inv_mul_cancelέΓΑ two_ne_zero,
    one_mul, pow_two]

/-- The symmetric covariance is symmetric in its observable arguments:
`Cov^s_╬▓(A, B) = Cov^s_╬▓(B, A)`. The anticommutator
`A ┬╖ B + B ┬╖ A = B ┬╖ A + A ┬╖ B` is unchanged under swap, and the product
`έθρAέθσ ┬╖ έθρBέθσ = έθρBέθσ ┬╖ έθρAέθσ` is commutative in `έΕΓ`. -/
theorem gibbsCovarianceSymm_comm (╬▓ : έΕζ) (H A B : ManyBodyOp ╬δ) :
    gibbsCovarianceSymm ╬▓ H A B = gibbsCovarianceSymm ╬▓ H B A := by
  unfold gibbsCovarianceSymm
  rw [add_comm (A * B) (B * A), mul_comm (gibbsExpectation ╬▓ H A)]

/-! #### Bilinearity of the symmetric covariance -/

/-- Additivity in the left argument:
`Cov^s_╬▓(AέΓΒ + AέΓΓ, B) = Cov^s_╬▓(AέΓΒ, B) + Cov^s_╬▓(AέΓΓ, B)`. -/
theorem gibbsCovarianceSymm_add_left (╬▓ : έΕζ) (H AέΓΒ AέΓΓ B : ManyBodyOp ╬δ) :
    gibbsCovarianceSymm ╬▓ H (AέΓΒ + AέΓΓ) B
      = gibbsCovarianceSymm ╬▓ H AέΓΒ B + gibbsCovarianceSymm ╬▓ H AέΓΓ B := by
  unfold gibbsCovarianceSymm
  have hexp : (AέΓΒ + AέΓΓ) * B + B * (AέΓΒ + AέΓΓ)
              = (AέΓΒ * B + B * AέΓΒ) + (AέΓΓ * B + B * AέΓΓ) := by
    rw [add_mul, mul_add]; abel
  rw [hexp, gibbsExpectation_add, gibbsExpectation_add,
      gibbsExpectation_add (╬▓ := ╬▓) (H := H) AέΓΒ AέΓΓ]
  ring

/-- Additivity in the right argument:
`Cov^s_╬▓(A, BέΓΒ + BέΓΓ) = Cov^s_╬▓(A, BέΓΒ) + Cov^s_╬▓(A, BέΓΓ)`. -/
theorem gibbsCovarianceSymm_add_right (╬▓ : έΕζ) (H A BέΓΒ BέΓΓ : ManyBodyOp ╬δ) :
    gibbsCovarianceSymm ╬▓ H A (BέΓΒ + BέΓΓ)
      = gibbsCovarianceSymm ╬▓ H A BέΓΒ + gibbsCovarianceSymm ╬▓ H A BέΓΓ := by
  rw [gibbsCovarianceSymm_comm ╬▓ H A (BέΓΒ + BέΓΓ),
      gibbsCovarianceSymm_add_left,
      gibbsCovarianceSymm_comm ╬▓ H BέΓΒ A, gibbsCovarianceSymm_comm ╬▓ H BέΓΓ A]

/-- Scalar pull-out from the left argument:
`Cov^s_╬▓(c έΑλ A, B) = c ┬╖ Cov^s_╬▓(A, B)`. -/
theorem gibbsCovarianceSymm_smul_left (╬▓ : έΕζ) (H : ManyBodyOp ╬δ) (c : έΕΓ)
    (A B : ManyBodyOp ╬δ) :
    gibbsCovarianceSymm ╬▓ H (c έΑλ A) B = c * gibbsCovarianceSymm ╬▓ H A B := by
  unfold gibbsCovarianceSymm
  have hexp : (c έΑλ A) * B + B * (c έΑλ A) = c έΑλ (A * B + B * A) := by
    rw [Matrix.smul_mul, Matrix.mul_smul, smul_add]
  rw [hexp, gibbsExpectation_smul, gibbsExpectation_smul]
  ring

/-- Scalar pull-out from the right argument:
`Cov^s_╬▓(A, c έΑλ B) = c ┬╖ Cov^s_╬▓(A, B)`. -/
theorem gibbsCovarianceSymm_smul_right (╬▓ : έΕζ) (H A : ManyBodyOp ╬δ) (c : έΕΓ)
    (B : ManyBodyOp ╬δ) :
    gibbsCovarianceSymm ╬▓ H A (c έΑλ B) = c * gibbsCovarianceSymm ╬▓ H A B := by
  rw [gibbsCovarianceSymm_comm ╬▓ H A (c έΑλ B),
      gibbsCovarianceSymm_smul_left,
      gibbsCovarianceSymm_comm ╬▓ H B A]

/-- The sum-of-observables variance identity:
`Var_╬▓(A + B) = Var_╬▓(A) + Var_╬▓(B) + 2 ┬╖ Cov^s_╬▓(A, B)`.
The cross term is the symmetric covariance (averaged anticommutator);
for commuting `A, B` it reduces to `2┬╖Cov(A, B)`. -/
theorem gibbsVariance_add (╬▓ : έΕζ) (H A B : ManyBodyOp ╬δ) :
    gibbsVariance ╬▓ H (A + B)
      = gibbsVariance ╬▓ H A + gibbsVariance ╬▓ H B
        + 2 * gibbsCovarianceSymm ╬▓ H A B := by
  unfold gibbsVariance gibbsCovarianceSymm
  have hexpand : (A + B) * (A + B) = A * A + A * B + B * A + B * B := by
    rw [add_mul, mul_add, mul_add]; abel
  rw [hexpand]
  simp only [gibbsExpectation_add]
  ring

/-! #### Variance under scalar / negation / constant shift -/

/-- Variance of the identity is zero when `Z έΚι 0`:
`Var_╬▓(1) = έθρ1έθσ - έθρ1έθσ┬▓ = 1 - 1 = 0`. -/
theorem gibbsVariance_one {H : ManyBodyOp ╬δ} (╬▓ : έΕζ)
    (hZ : partitionFn ╬▓ H έΚι 0) :
    gibbsVariance ╬▓ H 1 = 0 := by
  unfold gibbsVariance
  rw [Matrix.one_mul, gibbsExpectation_one ╬▓ hZ]
  ring

/-- Variance scales as the square: `Var_╬▓(c έΑλ A) = c┬▓ ┬╖ Var_╬▓(A)`. -/
theorem gibbsVariance_smul (╬▓ : έΕζ) (H : ManyBodyOp ╬δ) (c : έΕΓ) (A : ManyBodyOp ╬δ) :
    gibbsVariance ╬▓ H (c έΑλ A) = c ^ 2 * gibbsVariance ╬▓ H A := by
  unfold gibbsVariance
  rw [Matrix.smul_mul, Matrix.mul_smul, smul_smul, gibbsExpectation_smul,
    gibbsExpectation_smul]
  ring

/-- Variance of a scalar multiple of the identity is zero
(when `Z έΚι 0`): `Var_╬▓(c έΑλ 1) = c┬▓ ┬╖ 0 = 0`. -/
theorem gibbsVariance_smul_one {H : ManyBodyOp ╬δ} (╬▓ : έΕζ)
    (hZ : partitionFn ╬▓ H έΚι 0) (c : έΕΓ) :
    gibbsVariance ╬▓ H (c έΑλ (1 : ManyBodyOp ╬δ)) = 0 := by
  rw [gibbsVariance_smul, gibbsVariance_one ╬▓ hZ, mul_zero]

/-- Variance is invariant under negation: `Var_╬▓(έΙΤA) = Var_╬▓(A)`.
Specialisation of `gibbsVariance_smul` at `c = έΙΤ1`. -/
theorem gibbsVariance_neg (╬▓ : έΕζ) (H A : ManyBodyOp ╬δ) :
    gibbsVariance ╬▓ H (-A) = gibbsVariance ╬▓ H A := by
  rw [show -A = ((-1 : έΕΓ)) έΑλ A by simp]
  rw [gibbsVariance_smul]
  ring

/-- Variance is invariant under a constant additive shift
(when `Z έΚι 0`): `Var_╬▓(A + c έΑλ 1) = Var_╬▓(A)`. -/
theorem gibbsVariance_add_const_smul_one {H : ManyBodyOp ╬δ} (╬▓ : έΕζ)
    (hZ : partitionFn ╬▓ H έΚι 0) (A : ManyBodyOp ╬δ) (c : έΕΓ) :
    gibbsVariance ╬▓ H (A + c έΑλ (1 : ManyBodyOp ╬δ)) = gibbsVariance ╬▓ H A := by
  unfold gibbsVariance
  have hexp_self : (A + c έΑλ (1 : ManyBodyOp ╬δ)) * (A + c έΑλ 1)
                 = A * A + c έΑλ A + c έΑλ A + (c * c) έΑλ (1 : ManyBodyOp ╬δ) := by
    simp only [add_mul, mul_add, Matrix.smul_mul, Matrix.mul_smul,
      Matrix.one_mul, Matrix.mul_one, smul_smul]
    abel
  rw [hexp_self]
  simp only [gibbsExpectation_add, gibbsExpectation_smul,
    gibbsExpectation_one ╬▓ hZ]
  ring

/-! #### Symmetric / antisymmetric decomposition -/

/-- The complex covariance decomposes into its symmetric part plus
half the commutator expectation:
`Cov_╬▓(A, B) = Cov^s_╬▓(A, B) + (1/2) ┬╖ έθρA ┬╖ B έΙΤ B ┬╖ Aέθσ_╬▓`. -/
theorem gibbsCovariance_eq_symm_add_half_commutator
    (╬▓ : έΕζ) (H A B : ManyBodyOp ╬δ) :
    gibbsCovariance ╬▓ H A B
      = gibbsCovarianceSymm ╬▓ H A B
        + (2 : έΕΓ)έΒ╗┬╣ * gibbsExpectation ╬▓ H (A * B - B * A) := by
  unfold gibbsCovariance gibbsCovarianceSymm
  rw [gibbsExpectation_sub, gibbsExpectation_add]
  ring

/-- The symmetric covariance is the symmetrisation of the complex
covariance:
`Cov^s_╬▓(A, B) = (1/2) ┬╖ (Cov_╬▓(A, B) + Cov_╬▓(B, A))`. -/
theorem gibbsCovarianceSymm_eq_half_add_swap
    (╬▓ : έΕζ) (H A B : ManyBodyOp ╬δ) :
    gibbsCovarianceSymm ╬▓ H A B
      = (2 : έΕΓ)έΒ╗┬╣ * (gibbsCovariance ╬▓ H A B + gibbsCovariance ╬▓ H B A) := by
  unfold gibbsCovariance gibbsCovarianceSymm
  rw [gibbsExpectation_add]
  ring

/-- For commuting observables `A, B`, the complex covariance equals
the symmetric covariance: `Cov_╬▓(A, B) = Cov^s_╬▓(A, B)`. The
commutator-based antisymmetric part vanishes when `[A, B] = 0`. -/
theorem gibbsCovariance_eq_symm_of_commute (╬▓ : έΕζ) (H : ManyBodyOp ╬δ)
    {A B : ManyBodyOp ╬δ} (h : Commute A B) :
    gibbsCovariance ╬▓ H A B = gibbsCovarianceSymm ╬▓ H A B := by
  rw [gibbsCovariance_eq_symm_add_half_commutator]
  have hzero : A * B - B * A = 0 := by rw [h.eq, sub_self]
  rw [hzero]
  unfold gibbsExpectation
  rw [Matrix.mul_zero, Matrix.trace_zero, mul_zero, add_zero]

/-- The symmetric covariance vanishes when its left argument is a
scalar multiple of the identity, provided `Z(╬▓) έΚι 0`. Direct
corollary of `gibbsCovariance_const_smul_one_left_eq_zero` /
`_right_eq_zero` via the symmetrisation identity. -/
theorem gibbsCovarianceSymm_const_smul_one_left_eq_zero {H : ManyBodyOp ╬δ}
    (╬▓ : έΕζ) (hZ : partitionFn ╬▓ H έΚι 0) (c : έΕΓ) (B : ManyBodyOp ╬δ) :
    gibbsCovarianceSymm ╬▓ H (c έΑλ (1 : ManyBodyOp ╬δ)) B = 0 := by
  rw [gibbsCovarianceSymm_eq_half_add_swap,
    gibbsCovariance_const_smul_one_left_eq_zero ╬▓ hZ,
    gibbsCovariance_const_smul_one_right_eq_zero ╬▓ hZ]
  ring

/-- The symmetric covariance vanishes when its right argument is a
scalar multiple of the identity, provided `Z(╬▓) έΚι 0`. -/
theorem gibbsCovarianceSymm_const_smul_one_right_eq_zero {H : ManyBodyOp ╬δ}
    (╬▓ : έΕζ) (hZ : partitionFn ╬▓ H έΚι 0) (A : ManyBodyOp ╬δ) (c : έΕΓ) :
    gibbsCovarianceSymm ╬▓ H A (c έΑλ (1 : ManyBodyOp ╬δ)) = 0 := by
  rw [gibbsCovarianceSymm_comm,
    gibbsCovarianceSymm_const_smul_one_left_eq_zero ╬▓ hZ]

/-- For Hermitian `H` and Hermitian `A, B`, the symmetric covariance
is real. The anticommutator term is real by
`gibbsExpectation_anticommutator_im` (the (1/2) prefactor preserves
realness), and `έθρAέθσ ┬╖ έθρBέθσ` is the product of two real complex numbers. -/
theorem gibbsCovarianceSymm_im_of_isHermitian {H A B : ManyBodyOp ╬δ}
    (hH : H.IsHermitian) (hA : A.IsHermitian) (hB : B.IsHermitian) (╬▓ : έΕζ) :
    (gibbsCovarianceSymm ╬▓ H A B).im = 0 := by
  unfold gibbsCovarianceSymm
  have h_anti : (gibbsExpectation ╬▓ H (A * B + B * A)).im = 0 :=
    gibbsExpectation_anticommutator_im hH hA hB ╬▓
  have h_a : (gibbsExpectation ╬▓ H A).im = 0 :=
    gibbsExpectation_im_of_isHermitian hH hA ╬▓
  have h_b : (gibbsExpectation ╬▓ H B).im = 0 :=
    gibbsExpectation_im_of_isHermitian hH hB ╬▓
  have h_prod : (gibbsExpectation ╬▓ H A * gibbsExpectation ╬▓ H B).im = 0 := by
    rw [Complex.mul_im, h_a, h_b, zero_mul, mul_zero, add_zero]
  have h_inv : ((2 : έΕΓ)έΒ╗┬╣).im = 0 := by simp
  have h_half : ((2 : έΕΓ)έΒ╗┬╣ * gibbsExpectation ╬▓ H (A * B + B * A)).im = 0 := by
    rw [Complex.mul_im, h_inv, h_anti, mul_zero, zero_mul, add_zero]
  rw [Complex.sub_im, h_half, h_prod, sub_zero]

end LatticeSystem.Quantum

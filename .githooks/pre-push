#!/usr/bin/env bash
# pre-push — deterministic audit hard gate (blocks new decorative/duplicate decls).
#
# Tracked hook. Activate per-clone once with:
#   git config core.hooksPath .githooks
# See scripts/README-audit.md. CI is intentionally NOT used for this gate
# (local, grep-based, a few seconds). Ratchet mode (--diff main): existing
# debt is grandfathered; only newly-introduced violations are blocked.
set -euo pipefail
root="$(git rev-parse --show-toplevel)"
gate="$root/scripts/audit_gate.py"

if [ ! -f "$gate" ]; then
  echo "pre-push: scripts/audit_gate.py missing ($gate); restore the gate first." >&2
  exit 1
fi

# Git feeds "<local_ref> <local_sha> <remote_ref> <remote_sha>" per pushed ref on
# stdin. The gate audits the checked-out working tree (== HEAD), so fail closed if
# any pushed ref is not HEAD (e.g. push from another branch, --all); skip deletions.
head_sha="$(git rev-parse HEAD)"
zero="0000000000000000000000000000000000000000"
while read -r local_ref local_sha remote_ref remote_sha; do
  [ -z "${local_sha:-}" ] && continue
  [ "$local_sha" = "$zero" ] && continue            # branch deletion: nothing to audit
  if [ "$local_sha" != "$head_sha" ]; then
    echo "pre-push: the audit gate only supports pushing the checked-out HEAD" >&2
    echo "($head_sha); got $local_sha for '$local_ref'. Check out that ref and push." >&2
    exit 1
  fi
done

cd "$root"
if ! python3 "$gate" --diff main; then
  echo "" >&2
  echo "pre-push: hard gate blocked the push. Remove the decorative/duplicate" >&2
  echo "declaration above (rename does NOT help; delete or merge the entity)." >&2
  echo "A genuine capstone goes in scripts/audit/capstones.txt." >&2
  exit 1
fi
